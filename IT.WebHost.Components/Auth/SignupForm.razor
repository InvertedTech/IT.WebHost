@using IT.WebHost.Core.Models
@using BlazorBlueprint.Components

<form method="post" action="/signup">
    <BbCard class="w-full max-w-sm mx-auto">
        <BbCardHeader>
            <BbCardTitle>Create an account</BbCardTitle>
            <BbCardDescription>Enter your information below to create your account</BbCardDescription>
        </BbCardHeader>
        <BbCardContent>
            <div class="space-y-4">
                <div class="space-y-2">
                    <BbLabel for="UserName">Username</BbLabel>
                    <input type="text" name="UserName" value="@Model.UserName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <div class="space-y-2">
                    <BbLabel for="Email">Email</BbLabel>
                    <input type="email" name="Email" value="@Model.Email" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <div class="space-y-2">
                    <BbLabel for="FirstName">First Name</BbLabel>
                    <input type="text" name="FirstName" value="@Model.FirstName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <div class="space-y-2">
                    <BbLabel for="LastName">Last Name</BbLabel>
                    <input type="text" name="LastName" value="@Model.LastName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <div class="space-y-2">
                    <BbLabel for="PostalCode">Postal Code</BbLabel>
                    <input type="text" name="PostalCode" value="@Model.PostalCode" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <div class="space-y-2">
                    <BbLabel for="Password">Password</BbLabel>
                    <input type="password" name="Password" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <div class="space-y-2">
                    <BbLabel for="ConfirmPassword">Confirm Password</BbLabel>
                    <input type="password" name="ConfirmPassword" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                </div>
                <BbButton Type="ButtonType.Submit" class="w-full">Sign Up</BbButton>
            </div>
        </BbCardContent>
        <BbCardFooter class="text-center">
            <p class="text-sm text-muted-foreground">
                Already have an account? <a href="/login" class="text-primary underline-offset-4 hover:underline">Login</a>
            </p>
        </BbCardFooter>
    </BbCard>
</form>

@code {
    [Parameter] public SignupViewModel Model { get; set; } = new();
}
