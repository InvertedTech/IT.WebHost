@using IT.WebServices.Fragments.Content
@namespace IT.WebHost.Components.Content

<div class="bg-card rounded-lg border p-4 sm:p-6">
    <header class="w-full space-y-4" aria-label="Article information">

        <div class="flex flex-wrap gap-2" role="group" aria-label="Article status indicators">
            @if (ShowSubscriptionInfo)
            {
                <BbBadge Variant="@(Content?.Data?.SubscriptionLevel == 0 ? BadgeVariant.Secondary : BadgeVariant.Default)">
                    @GetSubscriptionLevelText(Content?.Data?.SubscriptionLevel)
                </BbBadge>
            }
        </div>

        <div class="flex items-start justify-between gap-4">
            <h1 class="text-2xl font-bold leading-tight tracking-tight text-foreground sm:text-3xl lg:text-4xl">
                @(Content?.Data?.Title ?? "Untitled Article")
            </h1>
            <div class="flex items-center gap-2 shrink-0">
                <ContentStatsSection ContentId="@(Content?.ContentID ?? string.Empty)" />
            </div>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 text-sm text-muted-foreground border-b pb-4">
            @if (!string.IsNullOrEmpty(Content?.Data?.Author))
            {
                <div class="flex items-center gap-1">
                    <span class="font-medium">By</span>
                    <span class="font-semibold text-foreground">@Content!.Data.Author</span>
                </div>
            }
            @if (_publishDate.HasValue)
            {
                <time datetime="@_publishDate.Value.ToString("o")" class="text-muted-foreground">
                    @_publishDate.Value.ToString("MMMM d, yyyy")
                </time>
            }
        </div>

        @if (!string.IsNullOrEmpty(Content?.Data?.Description))
        {
            <p class="text-lg text-muted-foreground leading-relaxed">
                @Content!.Data.Description
            </p>
        }

        @if (Content?.Data?.Tags is { Count: > 0 } tags)
        {
            <div class="flex flex-wrap gap-2" role="list" aria-label="Article tags">
                @foreach (var tag in tags)
                {
                    <BbBadge Variant="BadgeVariant.Outline" class="text-xs" role="listitem">
                        @tag
                    </BbBadge>
                }
            </div>
        }

    </header>
</div>

@code {
    [Parameter] public ContentPublicRecord? Content { get; set; }
    [Parameter] public bool ShowSubscriptionInfo { get; set; } = true;

    private DateTime? _publishDate;

    protected override void OnParametersSet()
    {
        _publishDate = Content?.PublishOnUTC?.ToDateTime() is { } dt && dt != default
            ? dt.ToLocalTime()
            : null;
    }

    private static string GetSubscriptionLevelText(uint? level) =>
        level is null or 0 ? "Free" : "Members Only";
}
