@namespace IT.WebHost.Components.Content

<div class="rounded-lg overflow-hidden">
    @if (_imageError || string.IsNullOrEmpty(AssetId))
    {
        @if (!string.IsNullOrEmpty(AssetId))
        {
            <div class="w-full max-h-[480px] h-72 bg-muted flex items-center justify-center rounded-lg">
                <span class="text-muted-foreground text-sm">Image unavailable</span>
            </div>
        }
    }
    else
    {
        <div class="relative w-full">
            @if (_imageLoading)
            {
                <BbSkeleton class="w-full h-72 rounded-lg" />
            }
            <img src="@($"http://localhost:8001/api/cms/asset/{AssetId}/data")"
                 alt="@Alt"
                 class="w-full object-cover max-h-[480px] rounded-lg @(_imageLoading ? "invisible absolute inset-0" : "")"
                 @onload="() => _imageLoading = false"
                 @onerror="OnImageError" />
                 <p>@Title</p>
        </div>
    }
</div>

@code {
    [Parameter] public string? AssetId { get; set; }
    [Parameter] public string Alt { get; set; } = "Featured image";
    [Parameter] public string? Title { get; set; } = null;

    private bool _imageLoading = true;
    private bool _imageError = false;

    protected override void OnParametersSet()
    {
        _imageLoading = true;
        _imageError = false;
    }

    private void OnImageError()
    {
        _imageError = true;
        _imageLoading = false;
    }
}
