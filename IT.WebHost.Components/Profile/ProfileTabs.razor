@using IT.WebHost.Components.Forms
@using IT.WebHost.Components.Payments
@using IT.WebHost.Core.Models

<BbTabs DefaultValue="account" class="w-full">
    <BbTabsList>
        <BbTabsTrigger Value="account">Account</BbTabsTrigger>
        <BbTabsTrigger Value="subscription">Subscription</BbTabsTrigger>
    </BbTabsList>
    <BbTabsContent Value="account" class="mx-auto">
        <ModifyOwnUserForm
            userId="@(Model.UserRecord?.UserId ?? string.Empty)"
            displayName="@(Model.UserRecord?.DisplayName ?? string.Empty)"
            bio="@(Model.UserRecord?.Bio ?? string.Empty)"
            email="@(Model.UserRecord?.Email ?? string.Empty)"
            firstName="@(Model.UserRecord?.FirstName ?? string.Empty)"
            lastName="@(Model.UserRecord?.LastName ?? string.Empty)"
            postalCode="@(Model.UserRecord?.PostalCode ?? string.Empty)" />
    </BbTabsContent>
    <BbTabsContent Value="subscription">
        @if (!Model.SubscriptionRecords.Any())
        {
            <p class="text-sm text-muted-foreground py-4">No subscriptions found.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var sub in Model.SubscriptionRecords)
                {
                    <SubscriptionItem Record="sub" />
                }
            </div>
        }
    </BbTabsContent>
</BbTabs>
@code {
    [Parameter] public ProfileViewModel Model { get; set; } = new();
}