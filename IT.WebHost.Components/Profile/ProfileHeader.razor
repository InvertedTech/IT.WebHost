@using IT.WebHost.Components.Forms.Fields
@using IT.WebHost.Core.Models
@namespace IT.WebHost.Components.Profile

@if (Model?.UserRecord is { } user)
{
    <div class="flex flex-row items-center gap-4">
        <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center text-xl font-bold shrink-0">
            @if (user.ProfileImagePNG.Length > 0)
            {
                <img src="@($"data:image/png;base64,{Convert.ToBase64String(user.ProfileImagePNG)}")"
                     alt="@user.DisplayName"
                     class="w-full h-full rounded-full object-cover" />
            }
            else
            {
                @GetInitials(user.DisplayName)
            }
        </div>
        <div class="flex flex-col">
            <span class="text-lg font-semibold leading-tight">@user.DisplayName</span>
            <span class="text-sm text-muted-foreground leading-tight">@@@user.UserName</span>
        </div>
        <ImageUploadField TriggerLabel="Change Picture" />
    </div>
    <BbSeparator class="my-4" />

    <div class="flex flex-row items-start gap-8 flex-wrap">
        @if (!string.IsNullOrWhiteSpace(user.Bio))
        {
            <div>
                <BbLabel>Bio</BbLabel>
                <p class="text-sm text-muted-foreground mt-1">@user.Bio</p>
            </div>
        }

        <div>
            <BbLabel>Member Since</BbLabel>
            <p class="text-sm text-muted-foreground mt-1">
                @user.CreatedOnUTC?.ToLocalTime().ToString("MMMM yyyy")
            </p>
        </div>

        <BbButton Variant="ButtonVariant.Outline" class="self-end ml-auto">Change Password</BbButton>
        <BbSeparator class="mb-4" />
    </div>
}

@code {
    [Parameter] public ProfileViewModel Model { get; set; } = new();

    private string GetInitials(string displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName)) return "?";
        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : displayName.Substring(0, Math.Min(2, displayName.Length)).ToUpper();
    }
}