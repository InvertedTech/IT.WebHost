@using BlazorBlueprint.Components
@namespace IT.WebHost.Components.Forms

<div class="flex justify-center py-12">
    <BbCard class="w-full max-w-sm">
        <BbCardHeader>
            <BbCardTitle>Login to your account</BbCardTitle>
            <BbCardDescription>Enter your credentials below to sign in</BbCardDescription>
        </BbCardHeader>
        <BbCardContent>
            <form method="post" action="/login">
                <input type="hidden" name="__RequestVerificationToken" value="@AntiforgeryToken" />
                <div class="space-y-4">
                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <BbAlert Variant="AlertVariant.Warning">
                            <BbAlertDescription>@Error</BbAlertDescription>
                        </BbAlert>
                    }
                    <div class="flex items-center justify-end">
                        <a href="#" class="text-sm text-muted-foreground underline-offset-4 hover:underline">
                            Forgot your password?
                        </a>
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string"  Name="UserName" Label="User Name"  
                            Placeholder="Enter username" ErrorText="@UserNameErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="Password" Label="Password"
                                          Placeholder="Enter Password" ErrorText="@PasswordErrorText" />
                    </div>
                    <BbButton Type="ButtonType.Submit" class="w-full">Login</BbButton>
                </div>
            </form>
        </BbCardContent>
        <BbCardFooter class="justify-center">
            <p class="text-sm text-muted-foreground">
                Don't have an account? <a href="/signup" class="text-primary underline-offset-4 hover:underline">Sign up</a>
            </p>
        </BbCardFooter>
    </BbCard>
</div>

@code {
    [Parameter] public string AntiforgeryToken { get; set; } = string.Empty;
    [Parameter] public string Error { get; set; } = string.Empty;
    [Parameter] public string UserNameErrorText { get; set; } = string.Empty;
    [Parameter] public string PasswordErrorText { get; set; } = string.Empty;
}
