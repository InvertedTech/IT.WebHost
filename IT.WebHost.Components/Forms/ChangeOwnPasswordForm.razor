@using IT.WebServices.Fragments.Authentication
@using IT.WebHost.Components.Extensions
@namespace IT.WebHost.Components.Forms

<BbDynamicForm Schema="@_schema"
               @bind-Values="_values"
               ShowSubmitButton="false" />

@code {
    [Parameter] public EventCallback<ChangeOwnPasswordRequest> OnSubmit { get; set; }
    [Parameter] public Action<Func<Task>>? RegisterSubmit { get; set; }

    private static readonly FormSchema _schema = FormSchemaExtensions.MapProtoToFormSchema(new ChangeOwnPasswordRequest());
    private Dictionary<string, object?> _values = new();

    protected override void OnInitialized() => RegisterSubmit?.Invoke(HandleSubmit);

    private async Task HandleSubmit()
    {
        var request = new ChangeOwnPasswordRequest
        {
            OldPassword = _values.GetString("OldPassword"),
            NewPassword = _values.GetString("NewPassword"),
        };
        await OnSubmit.InvokeAsync(request);
    }
}
