@using IT.WebServices.Fragments.Authentication
@using IT.WebHost.Components.Extensions
@namespace IT.WebHost.Components.Forms

<BbDynamicForm Schema="@_schema"
               @bind-Values="_values"
               ReadOnly="!EditModeEnabled"
               ShowSubmitButton="false" />

@if (EditModeEnabled)
{
    <BbButton Class="w-full" @onclick="HandleSubmit">Save Changes</BbButton>
    <BbButton Class="w-full" Variant="ButtonVariant.Outline" @onclick="ToggleEditMode">Discard Changes</BbButton>
}
else
{
    <BbButton Class="w-full" Variant="ButtonVariant.Outline" @onclick="ToggleEditMode">Edit</BbButton>
}

@code {
    [Parameter] public EventCallback<ModifyOwnUserRequest> OnSubmit { get; set; }
    [Parameter] public string userId { get; set; } = string.Empty;
    [Parameter] public string bio { get; set; } = string.Empty;
    [Parameter] public string displayName { get; set; } = string.Empty;
    [Parameter] public string email { get; set; } = string.Empty;
    [Parameter] public string firstName { get; set; } = string.Empty;
    [Parameter] public string lastName { get; set; } = string.Empty;
    [Parameter] public string postalCode { get; set; } = string.Empty;

    private bool EditModeEnabled { get; set; } = false;

    private static readonly FormSchema _schema = BuildSchema();
    private Dictionary<string, object?> _values = new();

    private static FormSchema BuildSchema()
    {
        var schema = FormSchemaExtensions.MapProtoToFormSchema(new ModifyOwnUserRequest());
        schema.Fields.RemoveAll(f => f.Name == "UserID");
        return schema;
    }

    protected override void OnParametersSet()
    {
        if (!EditModeEnabled)
            ResetValues();
    }

    private void ResetValues()
    {
        _values = new Dictionary<string, object?>
        {
            ["DisplayName"] = displayName,
            ["Email"]       = email,
            ["Bio"]         = bio,
            ["FirstName"]   = firstName,
            ["LastName"]    = lastName,
            ["PostalCode"]  = postalCode,
        };
    }

    private async Task HandleSubmit()
    {
        var request = new ModifyOwnUserRequest
        {
            UserID      = userId,
            DisplayName = _values.GetString("DisplayName"),
            Bio         = _values.GetString("Bio"),
            Email       = _values.GetString("Email"),
            FirstName   = _values.GetString("FirstName"),
            LastName    = _values.GetString("LastName"),
            PostalCode  = _values.GetString("PostalCode"),
        };
        await OnSubmit.InvokeAsync(request);
    }

    public void ToggleEditMode()
    {
        EditModeEnabled = !EditModeEnabled;
        if (!EditModeEnabled)
            ResetValues();
        StateHasChanged();
    }
}
