@using BlazorBlueprint.Components
@using IT.WebHost.Components.Forms.Fields
@using IT.WebServices.Fragments.Content
@using IT.WebServices.Fragments.Authorization
@using IT.WebServices.Fragments.Settings
@namespace IT.WebHost.Components.Forms

<div class="flex items-end gap-2">
    <SearchInput @bind-query="query" OnSearch="HandleSearchKey" />
    <PageSizeSelect @bind-pageSize="pageSize" />
    <SubscriptionLevelSelect Label="Min Level" @bind-SelectedLevel="minSubscriptionLevel" Tiers="Tiers" />
    <SubscriptionLevelSelect Label="Max Level" @bind-SelectedLevel="maxSubscriptionLevel" Tiers="Tiers" />
    <ChannelSelect @bind-Channels="Channels" @bind-SelectedChannel="channelId" />
    <CategorySelect @bind-Categories="Categories" @bind-SelectedCategory="categoryId" />
    <BbFormFieldTagInput Label="Tags"
                         @bind-Tags="tags" Placeholder="Add tag..." />
</div>

@code {
    [Parameter] public string query { get; set; } = string.Empty;
    [Parameter] public uint pageSize { get; set; } = 10;
    [Parameter] public uint pageOffset { get; set; } = 0;
    [Parameter] public ContentType? contentType { get; set; } = ContentType.ContentNone;
    [Parameter] public string? categoryId { get; set; }
    [Parameter] public string? channelId { get; set; }
    [Parameter] public IReadOnlyList<string> tags { get; set; } = new List<string>();
    [Parameter] public bool onlyLive { get; set; } = false;
    [Parameter] public uint minSubscriptionLevel { get; set; } = 0;
    [Parameter] public uint maxSubscriptionLevel { get; set; } = 0;
    [Parameter] public IEnumerable<SubscriptionTier> Tiers { get; set; } = [];
    [Parameter] public IEnumerable<ChannelRecord> Channels { get; set; } = [];
    [Parameter] public IEnumerable<CategoryRecord> Categories { get; set; } = [];

    [Inject] private NavigationManager Nav { get; set; } = null!;

    private void HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(query))
            Nav.NavigateTo(BuildUrl());
    }

    private string BuildUrl()
    {
        var qs = $"q={Uri.EscapeDataString(query)}&pageSize={pageSize}&pageOffset={pageOffset}";

        if (contentType.HasValue && contentType != ContentType.ContentNone)
            qs += $"&contentType={contentType}";
        if (!string.IsNullOrEmpty(categoryId))
            qs += $"&categoryId={Uri.EscapeDataString(categoryId)}";
        if (!string.IsNullOrEmpty(channelId))
            qs += $"&channelId={Uri.EscapeDataString(channelId)}";
        // if (!string.IsNullOrEmpty(tag))
        //     qs += $"&tag={Uri.EscapeDataString(tag)}";
        if (tags.Count() > 0)
        {
            var tagsString = BuildTags(tags);
            qs += tagsString;
        }
        if (onlyLive)
            qs += "&onlyLive=true";
        if (minSubscriptionLevel > 0)
            qs += $"&minSubscriptionLevel={minSubscriptionLevel}";
        if (maxSubscriptionLevel > 0)
            qs += $"&maxSubscriptionLevel={maxSubscriptionLevel}";

        return $"/search?{qs}";
    }

    private string BuildTags(IReadOnlyList<string> _tags)
    {
        var tagsString = "";
        foreach (var tag in _tags)
        {
            if (!string.IsNullOrWhiteSpace(tagsString))
                tagsString += ",";
            tagsString += Uri.EscapeDataString(tag);
        }
        ;

        return $"&tags=[{tagsString}]";
    }
}