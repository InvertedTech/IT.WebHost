@using System.ComponentModel.DataAnnotations
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms
@using IT.WebHost.Components.Validation
@using IT.WebServices.Fragments.Authentication

<EditForm EditContext="editContext">
    <DataAnnotationsValidator />
    <ProtoValidateValidator TMessage="CreateUserRequest" MessageFactory="@BuildRequest" />
    <BbFormWizard OnComplete="HandleSubmit">
        <BbWizardStep Title="Account" Icon="user"
                      FieldNames="@(new[] { "UserName", "Email", "Password", "ConfirmPassword" })">
            <div class="space-y-4 max-w-md">
                <BbFormFieldInput TValue="string"
                    Label="Username"
                    @bind-Value="model.UserName"
                    ErrorText="@GetError(() => model.UserName)"
                    HelperText="At least 3 characters"
                    Placeholder="johndoe" />
                <BbFormFieldInput TValue="string"
                    Label="Email"
                    @bind-Value="model.Email"
                    ErrorText="@GetError(() => model.Email)"
                    Placeholder="you@example.com" />
                <BbFormFieldInput TValue="string"
                    Label="Password"
                    Type="InputType.Password"
                    @bind-Value="model.Password"
                    ErrorText="@GetError(() => model.Password)"
                    HelperText="At least 6 characters" />
                <BbFormFieldInput TValue="string"
                    Label="Confirm Password"
                    Type="InputType.Password"
                    @bind-Value="model.ConfirmPassword"
                    ErrorText="@GetError(() => model.ConfirmPassword)" />
            </div>
        </BbWizardStep>
        <BbWizardStep Title="Profile" Icon="id-card"
                      FieldNames="@(new[] { "FirstName", "LastName", "DisplayName", "PostalCode" })">
            <div class="space-y-4 max-w-md">
                <BbFormFieldInput TValue="string"
                    Label="First Name"
                    @bind-Value="model.FirstName"
                    ErrorText="@GetError(() => model.FirstName)"
                    Placeholder="Jane" />
                <BbFormFieldInput TValue="string"
                    Label="Last Name"
                    @bind-Value="model.LastName"
                    ErrorText="@GetError(() => model.LastName)"
                    Placeholder="Doe" />
                <BbFormFieldInput TValue="string"
                    Label="Display Name"
                    @bind-Value="model.DisplayName"
                    ErrorText="@GetError(() => model.DisplayName)"
                    HelperText="Public-facing name (optional)"
                    Placeholder="Jane Doe" />
                <BbField Label="Bio">
                    <BbTextarea @bind-Value="model.Bio"
                                Placeholder="Tell us about yourself..." />
                </BbField>
                <BbFormFieldInput TValue="string"
                    Label="Postal / Zip Code"
                    @bind-Value="model.PostalCode"
                    ErrorText="@GetError(() => model.PostalCode)"
                    Placeholder="12345" />
            </div>
        </BbWizardStep>
        <BbWizardStep Title="Review" Icon="circle-check">
            <div class="rounded-lg border p-4 space-y-2 max-w-md">
                <p class="text-sm"><strong>Username:</strong> @model.UserName</p>
                <p class="text-sm"><strong>Email:</strong> @model.Email</p>
                <p class="text-sm"><strong>Name:</strong> @model.FirstName @model.LastName</p>
                @if (!string.IsNullOrEmpty(model.DisplayName))
                {
                    <p class="text-sm"><strong>Display Name:</strong> @model.DisplayName</p>
                }
                <p class="text-sm"><strong>Postal Code:</strong> @model.PostalCode</p>
            </div>
        </BbWizardStep>
    </BbFormWizard>
</EditForm>

@code {
    private RegistrationModel model = new();
    private EditContext editContext = null!;

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
    }

    private string GetError<T>(Expression<Func<T>> accessor)
    {
        var fi = FieldIdentifier.Create(accessor);
        return editContext.GetValidationMessages(fi).FirstOrDefault() ?? string.Empty;
    }

    private class RegistrationModel
    {
        public string UserName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";

        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string? DisplayName { get; set; }
        public string? Bio { get; set; }
        public string PostalCode { get; set; } = "";
    }

    private CreateUserRequest BuildRequest() => new()
    {
        UserName    = model.UserName    ?? "",
        Email       = model.Email       ?? "",
        Password    = model.Password    ?? "",
        FirstName   = model.FirstName   ?? "",
        LastName    = model.LastName    ?? "",
        DisplayName = model.DisplayName ?? "",
        Bio         = model.Bio         ?? "",
        PostalCode  = model.PostalCode  ?? "",
    };

    private void HandleSubmit() { /* Save registration */ }
}
