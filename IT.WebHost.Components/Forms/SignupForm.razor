@using BlazorBlueprint.Components
@namespace IT.WebHost.Components.Forms

<div class="flex justify-center py-12">
    <BbCard class="w-full max-w-sm">
        <BbCardHeader>
            <BbCardTitle>Create an account</BbCardTitle>
            <BbCardDescription>Enter your information below to get started</BbCardDescription>
        </BbCardHeader>
        <BbCardContent>
            <form method="post" action="/signup">
                <input type="hidden" name="__RequestVerificationToken" value="@AntiforgeryToken" />
                <div class="space-y-4">
                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <BbAlert Variant="AlertVariant.Warning">
                            <BbAlertDescription>@Error</BbAlertDescription>
                        </BbAlert>
                    }
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="UserName" Label="Username"
                                          Placeholder="Enter username" ErrorText="@UserNameErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="DisplayName" Label="Display Name"
                                          Placeholder="Enter display name" ErrorText="@DisplayNameErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="Email" Label="Email"
                                          Placeholder="Enter email address" ErrorText="@EmailErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="FirstName" Label="First Name"
                                          Placeholder="Enter first name" ErrorText="@FirstNameErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="LastName" Label="Last Name"
                                          Placeholder="Enter last name" ErrorText="@LastNameErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="PostalCode" Label="Postal / Zip Code"
                                          Placeholder="Enter postal code" ErrorText="@PostalCodeErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="Password" Label="Password"
                                          Placeholder="Enter password" ErrorText="@PasswordErrorText" />
                    </div>
                    <div class="space-y-2">
                        <BbFormFieldInput TValue="string" Name="ConfirmPassword" Label="Confirm Password"
                                          Placeholder="Confirm your password" ErrorText="@ConfirmPasswordErrorText" />
                    </div>
                    <BbButton Type="ButtonType.Submit" class="w-full">Create Account</BbButton>
                </div>
            </form>
        </BbCardContent>
        <BbCardFooter class="justify-center">
            <p class="text-sm text-muted-foreground">
                Already have an account? <a href="/login" class="text-primary underline-offset-4 hover:underline">Login</a>
            </p>
        </BbCardFooter>
    </BbCard>
</div>

@code {
    [Parameter] public string AntiforgeryToken { get; set; } = string.Empty;
    [Parameter] public string Error { get; set; } = string.Empty;
    [Parameter] public string UserNameErrorText { get; set; } = string.Empty;
    [Parameter] public string DisplayNameErrorText { get; set; } = string.Empty;
    [Parameter] public string EmailErrorText { get; set; } = string.Empty;
    [Parameter] public string PasswordErrorText { get; set; } = string.Empty;
    [Parameter] public string ConfirmPasswordErrorText { get; set; } = string.Empty;
    [Parameter] public string FirstNameErrorText { get; set; } = string.Empty;
    [Parameter] public string LastNameErrorText { get; set; } = string.Empty;
    [Parameter] public string PostalCodeErrorText { get; set; } = string.Empty;
}
