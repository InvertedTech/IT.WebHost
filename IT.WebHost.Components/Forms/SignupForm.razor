@using IT.WebServices.Fragments.Authentication
@using IT.WebHost.Components.Extensions
@namespace IT.WebHost.Components.Forms

<div class="flex justify-center py-12">
    <BbCard class="w-full max-w-sm">
        <BbCardHeader>
            <BbCardTitle>Create an account</BbCardTitle>
            <BbCardDescription>Enter your information below to get started</BbCardDescription>
        </BbCardHeader>
        <BbCardContent>
            <BbDynamicForm Schema="@_schema"
                           SubmitText="Create Account"
                           OnValidSubmit="HandleSubmit" />
        </BbCardContent>
        <BbCardFooter class="justify-center">
            <p class="text-sm text-muted-foreground">
                Already have an account? <a href="/login" class="text-primary underline-offset-4 hover:underline">Login</a>
            </p>
        </BbCardFooter>
    </BbCard>
</div>

@code {
    [Parameter] public EventCallback<CreateUserRequest> OnSubmit { get; set; }

    private readonly FormSchema _schema = BuildSchema();

    private static FormSchema BuildSchema()
    {
        var schema = FormSchemaExtensions.MapProtoToFormSchema(new CreateUserRequest());
        schema.Fields.RemoveAll(f => f.Name == "Bio");
        schema.Fields.Add(new FormFieldDefinition
        {
            Name = "ConfirmPassword",
            Label = "Confirm Password",
            Type = FieldType.Password,
            Required = true,
            Order = 99
        });
        return schema;
    }

    private async Task HandleSubmit(Dictionary<string, object?> values)
    {
        var request = new CreateUserRequest
        {
            UserName    = values.GetString("UserName"),
            DisplayName = values.GetString("DisplayName"),
            Email       = values.GetString("Email"),
            Password    = values.GetString("Password"),
            FirstName   = values.GetString("FirstName"),
            LastName    = values.GetString("LastName"),
            PostalCode  = values.GetString("PostalCode"),
            Bio         = string.Empty
        };
        await OnSubmit.InvokeAsync(request);
    }
}
