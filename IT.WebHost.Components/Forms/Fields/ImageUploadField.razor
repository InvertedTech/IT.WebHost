@namespace IT.WebHost.Components.Forms.Fields

<BbDialog @bind-Open="IsOpen">
    @if (ShowTrigger)
    {
        <BbDialogTrigger>
            <BbButton Variant="ButtonVariant.Outline">@(TriggerLabel)</BbButton>
        </BbDialogTrigger>
    }
    <BbDialogContent>
        <BbDialogHeader>
            <BbFormFieldFileUpload @bind-Files="files"
                                   Label="Upload An Image"
                                   MaxFileCount="MaxFileCount" />
        </BbDialogHeader>
        <BbDialogFooter>
            <BbButton @onclick="() => IsOpen = false">Close</BbButton>
            <BbButton>Continue</BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    [Parameter] public string TriggerLabel { get; set; } = "Upload Image";
    [Parameter] public int MaxFileCount { get; set; } = 1;
    [Parameter] public bool ShowTrigger { get; set; } = true;
    [Parameter] public bool IsOpen { get; set; } = false;

    private IReadOnlyList<FileUploadItem>? files;
}