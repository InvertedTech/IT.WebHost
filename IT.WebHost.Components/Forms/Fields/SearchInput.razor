@namespace IT.WebHost.Components.Forms.Fields

<div class="relative">
    <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-muted-foreground pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
    </svg>
    <BbInput placeholder="Search..." class="w-full pl-8" @onkeydown="OnSearch" @bind-Value="_query" />
</div>

@code {
    [Parameter] public string query { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> queryChanged { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnSearch { get; set; }

    private string _query
    {
        get => query;
        set
        {
            query = value;
            queryChanged.InvokeAsync(value);
        }
    }
}