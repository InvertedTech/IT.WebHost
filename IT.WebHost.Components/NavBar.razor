@using BlazorBlueprint.Components
@using IT.WebHost.Core.Services
@namespace IT.WebHost.Components
@inject SiteSettingsService SiteSettings

<BbResponsiveNavProvider>

    <header class="sticky top-0 z-50 w-full border-b bg-background">
        <div class="container flex h-14 items-center justify-between">

            <div class="flex items-center gap-4">
                <BbResponsiveNavTrigger />
                <a href="/" class="flex items-center space-x-2">
                    <svg class="text-primary" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                        <polyline points="7.5,4.27 12,6.11 16.5,4.27"></polyline>
                        <polyline points="7.5,9.73 12,11.57 16.5,9.73"></polyline>
                        <polyline points="7.5,15.19 12,16.03 16.5,15.19"></polyline>
                    </svg>
                    <span class="font-bold">@SiteSettings.SiteTitle</span>
                </a>
            </div>

            <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
                @foreach (var item in _navItems)
                {
                    <a href="@item.Href" class="text-foreground/60 hover:text-foreground transition-colors">@item.Text</a>
                }
            </nav>

            <div class="hidden md:flex items-center gap-2">
                <div class="relative">
                    <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-muted-foreground pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                    <BbInput placeholder="Search..." class="w-40 pl-8 h-9" @onkeydown="HandleSearchKey" @bind-Value="_searchQuery" />
                </div>
                @if (IsAuthenticated)
                {
                    <a href="/profile" class="text-sm font-medium text-foreground/60 hover:text-foreground transition-colors">Profile</a>
                    <a href="/auth/logout" class="text-sm font-medium text-foreground/60 hover:text-foreground transition-colors">Log out</a>
                }
                else
                {
                    <a href="/login"><BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small">Login</BbButton></a>
                    <a href="/signup"><BbButton Size="ButtonSize.Small">Sign Up</BbButton></a>
                }
            </div>

        </div>
    </header>

    <BbResponsiveNavContent>
        <Header>
            <a href="/" class="flex items-center space-x-2">
                <svg class="text-primary" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    <polyline points="7.5,4.27 12,6.11 16.5,4.27"></polyline>
                    <polyline points="7.5,9.73 12,11.57 16.5,9.73"></polyline>
                    <polyline points="7.5,15.19 12,16.03 16.5,15.19"></polyline>
                </svg>
                <span class="font-bold">@SiteSettings.SiteTitle</span>
            </a>
        </Header>
        <ChildContent>
            <div class="relative mb-3">
                <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-muted-foreground pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <BbInput placeholder="Search..." class="w-full pl-8" @onkeydown="HandleSearchKey" @bind-Value="_searchQuery" />
            </div>
            <nav class="flex flex-col gap-1">
                <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Navigation</p>
                @foreach (var item in _navItems)
                {
                    <a href="@item.Href" class="text-sm font-medium py-2 hover:text-primary transition-colors">@item.Text</a>
                }
            </nav>
        </ChildContent>
        <Footer>
            <div class="flex flex-col gap-2 pt-4 border-t">
                @if (IsAuthenticated)
                {
                    <a href="/profile"><BbButton Variant="ButtonVariant.Outline" class="w-full">Profile</BbButton></a>
                    <a href="/auth/logout"><BbButton Variant="ButtonVariant.Ghost" class="w-full">Log out</BbButton></a>
                }
                else
                {
                    <a href="/signup"><BbButton class="w-full">Sign Up</BbButton></a>
                    <a href="/login"><BbButton Variant="ButtonVariant.Outline" class="w-full">Login</BbButton></a>
                }
            </div>
        </Footer>
    </BbResponsiveNavContent>

</BbResponsiveNavProvider>

@code {
    [Parameter] public bool IsAuthenticated { get; set; }

    private string _searchQuery = string.Empty;

    [Inject] private NavigationManager Nav { get; set; } = null!;

    private void HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}");
    }

    private static readonly (string Text, string Href)[] _navItems =
    [
        ("Home", "/"),
        ("Subscribe", "/subscribe"),
        ("Members Area", "/members-area"),
        ("Search", "/search"),
        ("Merch", "/merch"),
    ];
}
