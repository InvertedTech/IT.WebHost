@page "/not-found"

<PageTitle>Page Not Found</PageTitle>

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="max-w-2xl w-full space-y-6 text-center">
        <div class="flex justify-center">
            <div class="relative">
                <div class="absolute inset-0 bg-primary/20 blur-3xl rounded-full"></div>
                <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative text-primary">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                    <path d="M11 8v6"></path>
                    <path d="M8 11h6"></path>
                </svg>
            </div>
        </div>

        <div class="space-y-3">
            <h1 class="text-6xl font-bold tracking-tight">404</h1>
            <h2 class="text-2xl font-semibold">Page Not Found</h2>
            <p class="text-lg text-muted-foreground max-w-md mx-auto">
                Sorry, we couldn't find the page you're looking for. The content you are trying to access does not exist or has been moved.
            </p>
        </div>

        <Card class="text-left">
            <CardHeader>
                <CardTitle>What can you do?</CardTitle>
            </CardHeader>
            <CardContent class="space-y-3">
                <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    </svg>
                    <div class="space-y-1">
                        <p class="font-medium">Return to Home</p>
                        <p class="text-sm text-muted-foreground">Start fresh from the homepage</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                    <div class="space-y-1">
                        <p class="font-medium">Check the URL</p>
                        <p class="text-sm text-muted-foreground">Make sure the address is spelled correctly</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                        <path d="M3 3v5h5"></path>
                    </svg>
                    <div class="space-y-1">
                        <p class="font-medium">Go Back</p>
                        <p class="text-sm text-muted-foreground">Return to the previous page</p>
                    </div>
                </div>
            </CardContent>
            <CardFooter class="gap-2">
                <Button OnClick="@GoHome" Class="flex-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    </svg>
                    Go to Home
                </Button>
                <Button OnClick="@GoBack" Variant="ButtonVariant.Outline" Class="flex-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                        <path d="m12 19-7-7 7-7"></path>
                        <path d="M19 12H5"></path>
                    </svg>
                    Go Back
                </Button>
            </CardFooter>
        </Card>

        <Card>
            <CardHeader>
                <CardTitle>Popular Pages</CardTitle>
                <CardDescription>You might be looking for one of these</CardDescription>
            </CardHeader>
            <CardContent>
                <div class="grid gap-2">
                    <a href="/" class="flex items-center gap-2 p-3 rounded-md hover:bg-accent transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        </svg>
                        <span class="text-sm font-medium">Home</span>
                    </a>
                    <a href="/counter" class="flex items-center gap-2 p-3 rounded-md hover:bg-accent transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                            <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                            <path d="M12 8v8"></path>
                            <path d="M8 12h8"></path>
                        </svg>
                        <span class="text-sm font-medium">Counter</span>
                    </a>
                    <a href="/weather" class="flex items-center gap-2 p-3 rounded-md hover:bg-accent transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                            <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"></path>
                        </svg>
                        <span class="text-sm font-medium">Weather</span>
                    </a>
                </div>
            </CardContent>
        </Card>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }
}
