<script src="@Assets["js/app-loader.js"]"></script>

<!-- App Initialization Loader - Bottom slide-up panel (matches blazor-error-ui style) -->
<div id="app-loader" class="app-loader" data-nosnippet>
    <!-- Transparent overlay to block interactions during WASM load -->
    <div class="app-loader-overlay"></div>
    
    <!-- Loader content -->
    <div class="max-w-4xl mx-auto bg-card border border-muted rounded-lg p-4 shadow-lg pointer-events-auto animate-slide-up relative z-10">
        <div class="flex items-center gap-3">
            <!-- Loading Animation Icon -->
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 relative">
                <!-- Static background ring -->
                <div class="absolute h-8 w-8 border-2 border-primary/30 rounded-full"></div>
                <!-- Spinning segment (only top border visible) -->
                <div class="absolute h-8 w-8 rounded-full animate-spin spinner-ring"></div>
                <!-- Center icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary relative z-10">
                    <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
                </svg>
            </div>

            <!-- Text Content -->
            <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-sm">Initializing Application</h3>
                <p class="text-xs text-muted-foreground mt-0.5">
                    <span id="app-loader-status">Loading WebAssembly runtime and resources...</span>
                    <span id="app-loader-percentage" class="ml-2 font-mono font-semibold text-primary"></span>
                </p>
            </div>

            <!-- Progress Bar (subtle, inline) -->
            <div class="hidden sm:block w-32 h-2 bg-muted rounded-full overflow-hidden relative">
                <div id="app-loader-progress" class="h-full bg-primary transition-all duration-300 ease-out" style="width: 0%"></div>
                <!-- Shimmer effect for indeterminate state -->
                <div id="app-loader-shimmer" class="app-loader-shimmer"></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* App Loader Base Styles */
    .app-loader {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 50;
        padding: 1rem;
        pointer-events: none;
        display: none;
    }
    
    .app-loader.show {
        display: block;
    }
    
    .app-loader.hiding {
        opacity: 0;
        transition: opacity 0.4s ease-out;
    }
    
    /* Transparent overlay to block interactions */
    .app-loader-overlay {
        position: fixed;
        inset: 0;
        background-color: transparent;
        pointer-events: auto;
        z-index: 1;
    }
    
    /* Dark mode overlay */
    @@media (prefers-color-scheme: dark) {
        .app-loader-overlay {
            background-color: rgba(0, 0, 0, 0.3);
        }
    }
    
    html.dark .app-loader-overlay {
        background-color: rgba(0, 0, 0, 0.3);
    }
    
    /* Spinner ring - only show top border segment */
    .spinner-ring {
        border: 2px solid transparent;
        border-top-color: var(--primary);
        border-radius: 9999px;
    }
    
    /* Ensure spinner animation works (fallback if Tailwind not loaded) */
    .app-loader .animate-spin {
        animation: spin 1s linear infinite;
    }
    
    .app-loader-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, transparent, color-mix(in oklch, var(--primary) 50%, transparent), transparent);
        display: none;
        animation: shimmer 2s infinite;
    }
    
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
</style>
