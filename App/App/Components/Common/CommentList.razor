@using IT.WebHost.Components.Comments
@using IT.WebServices.Fragments.Comment

@if (!Comments.Any())
{
    <Empty >
        <EmptyTitle>No Comments Yet</EmptyTitle>
        <EmptyDescription>Be The First</EmptyDescription>

        <LucideIcon Name="search" class="h-12 w-12" />
    </Empty>
} else
{
    <div class="flex flex-col divide-y">
        @foreach (var  comment in Comments) {
            <CommentItem Comment="comment" />
        }
    </div>
}

@code {
    [Parameter] public IEnumerable<CommentResponseRecord> Comments { get; set; } = new List<CommentResponseRecord>();
}
