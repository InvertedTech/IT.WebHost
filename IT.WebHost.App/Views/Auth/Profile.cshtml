@model IT.WebHost.App.Models.ProfileViewModel

@if (Model.UserRecord == null)
{
    <div class="flex flex-1 items-center justify-center py-12">
        <p class="text-muted-foreground">You must be logged in to view this page. <a href="/auth/login" class="text-primary underline-offset-4 hover:underline">Sign in</a></p>
    </div>
}
else
{
    <div class="container max-w-2xl py-12 mx-auto">
        <div class="flex flex-col items-center text-center gap-4">
            <div class="w-24 h-24 bg-muted rounded-full flex items-center justify-center text-2xl font-bold">
                @if (Model.UserRecord.Public.Data.ProfileImagePNG.Length > 0)
                {
                    <img src="@($"data:image/png;base64,{Convert.ToBase64String(Model.UserRecord.Public.Data.ProfileImagePNG.ToByteArray())}")"
                         alt="@Model.UserRecord.Public.Data.DisplayName" class="w-full h-full rounded-full object-cover" />
                }
                else
                {
                    @GetInitials(Model.UserRecord.Public.Data.DisplayName)
                }
            </div>

            <div class="space-y-1">
                <h1 class="text-2xl font-bold">@Model.UserRecord.Public.Data.DisplayName</h1>
                <p class="text-sm text-muted-foreground">@@@Model.UserRecord.Public.Data.UserName</p>
                <button class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">
                    Change Password
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.UserRecord.Public.Data.Bio))
            {
                <p class="text-sm text-muted-foreground max-w-md">@Model.UserRecord.Public.Data.Bio</p>
            }

            @if (Model.UserRecord.Private?.Roles.Count > 0)
            {
                <div class="flex flex-wrap justify-center gap-2">
                    @foreach (var role in Model.UserRecord.Private.Roles)
                    {
                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80">@role</span>
                    }
                </div>
            }

            <p class="text-xs text-muted-foreground">
                Member since @Model.UserRecord.Public.CreatedOnUTC?.ToDateTime().ToLocalTime().ToString("MMMM yyyy")
            </p>
        </div>
    </div>
}

@functions {
    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Split(' ');
        return string.Concat(parts.Take(2).Select(p => p.Length > 0 ? p[0] : '?'));
    }
}