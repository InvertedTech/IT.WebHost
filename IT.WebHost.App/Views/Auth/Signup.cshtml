@model IT.WebHost.App.Models.SignupViewModel

<div class="flex flex-1 items-center justify-center">
    <div class="w-full max-w-sm bg-card text-card-foreground rounded-lg border shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="text-2xl font-semibold leading-none tracking-tight">Create an account</h3>
            <p class="text-sm text-muted-foreground">Enter your information below to create your account</p>
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-red-600 text-sm">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }
        </div>
        <div class="p-6 pt-0">
            <form asp-action="Signup" method="post" class="space-y-4">
                <div class="space-y-2">
                    <label asp-for="UserName" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Username</label>
                    <input asp-for="UserName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" placeholder="johndoe" />
                    <span asp-validation-for="UserName" class="text-red-600 text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="DisplayName" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Display Name</label>
                    <input asp-for="DisplayName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" placeholder="johndoe" />
                    <span asp-validation-for="DisplayName" class="text-red-600 text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Email" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Email</label>
                    <input asp-for="Email" type="email" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" placeholder="m@example.com" />
                    <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                    <p class="text-xs text-muted-foreground">We'll use this to contact you. We will not share your email with anyone else.</p>
                </div>

                <div class="space-y-2">
                    <label asp-for="Password" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Password</label>
                    <input asp-for="Password" type="password" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                    <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
                    <p class="text-xs text-muted-foreground">Must be at least 8 characters long.</p>
                </div>

                <div class="space-y-2">
                    <label asp-for="ConfirmPassword" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm"></span>
                    <p class="text-xs text-muted-foreground">Please confirm your password.</p>
                </div>

                <div class="space-y-2">
                    <label asp-for="FirstName" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">First Name</label>
                    <input asp-for="FirstName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                    <span asp-validation-for="FirstName" class="text-red-600 text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="LastName" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Last Name</label>
                    <input asp-for="LastName" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                    <span asp-validation-for="LastName" class="text-red-600 text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="PostalCode" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">Postal/Zip Code</label>
                    <input asp-for="PostalCode" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                    <span asp-validation-for="PostalCode" class="text-red-600 text-sm"></span>
                </div>

                <button type="submit" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 w-full">
                    Create Account
                </button>
            </form>
        </div>
        <div class="flex flex-col space-y-1.5 p-6 pt-0">
            <div class="w-full text-center text-sm text-muted-foreground">
                Already have an account?
                <a href="/auth/login" class="text-primary underline-offset-4 hover:underline">Sign in</a>
            </div>
        </div>
    </div>
</div>