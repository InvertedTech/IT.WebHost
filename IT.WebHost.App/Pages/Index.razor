@page "/"
@using IT.WebHost.Components.Content
@using IT.WebHost.Core.Clients
@using IT.WebServices.Fragments.Content
@inject ContentClient ContentClient
@inject IT.WebHost.Core.Services.SiteSettingsService SiteSettings

<PageTitle>Home - @SiteSettings.SiteTitle</PageTitle>

<div class="container py-10">
    @switch (SiteSettings.Settings?.CMS?.DefaultLayout)
    {
        case LayoutEnum.Grid:
            <ContentGridView Content="@contentListRecords" />
            break;
        case LayoutEnum.Masonry:
            <ContentMasonryView Content="@contentListRecords" />
            break;
        default:
            <ContentListView Content="@contentListRecords" />
            break;
    }

</div>

@code {
    private readonly List<ContentListRecord> contentListRecords = new List<ContentListRecord>();

    protected override async Task OnInitializedAsync()
    {
        var req = new GetAllContentRequest
        {
            // TODO: Remove offset
            PageOffset = 50,
            PageSize = 10,
        };

        var res = await ContentClient.GetAllContentAsync(req);

        if (res.PageTotalItems > 0)
        {
            contentListRecords.AddRange(res.Records);
        }
    }
}
