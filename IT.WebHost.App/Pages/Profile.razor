@page "/profile"
@using IT.WebHost.Components.Forms
@using IT.WebServices.Fragments.Authentication
@using IT.WebHost.Core.Clients
@using Microsoft.AspNetCore.Components.Authorization
@inject IT.WebHost.Core.Services.SiteSettingsService SiteSettings
@inject IT.WebHost.Core.Clients.AuthClient authClient
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<PageTitle>Profile - @SiteSettings.SiteTitle</PageTitle>

<AuthorizeView>
    <Authorizing></Authorizing>
    <Authorized>
        @if (record is not null)
        {
            <div class="container max-w-2xl py-12">
                <div class="flex flex-col items-center text-center gap-4">
                    <BbAvatar Size="AvatarSize.ExtraLarge">
                        @if (record.Public.Data.ProfileImagePNG.Length > 0)
                        {
                            <BbAvatarImage Source="@($"data:image/png;base64,{Convert.ToBase64String(record.Public.Data.ProfileImagePNG.ToByteArray())}")"
                                        Alt="@record.Public.Data.DisplayName" />
                        }
                        <BbAvatarFallback>@Initials</BbAvatarFallback>
                    </BbAvatar>

                    <div class="space-y-1">
                        <h1 class="text-2xl font-bold">@record.Public.Data.DisplayName</h1>
                        <p class="text-sm text-muted-foreground">@@@record.Public.Data.UserName</p>
                        <FormDialog Label="Change Password" Title="Change Your Password">
                            <ChildContent Context="registerSubmit">
                                <ChangeOwnPasswordForm 
                                    RegisterSubmit="@registerSubmit" 
                                    OnSubmit="HandleChangePasswordSubmit" />
                            </ChildContent>
                        </FormDialog>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(record.Public.Data.Bio))
                    {
                        <p class="text-sm text-muted-foreground max-w-md">@record.Public.Data.Bio</p>
                    }

                    @if (record.Private?.Roles.Count > 0)
                    {
                        <div class="flex flex-wrap justify-center gap-2">
                            @foreach (var role in record.Private.Roles)
                            {
                                <BbBadge Variant="BadgeVariant.Secondary">@role</BbBadge>
                            }
                        </div>
                    }

                    <p class="text-xs text-muted-foreground">
                        Member since @record.Public.CreatedOnUTC?.ToDateTime().ToLocalTime().ToString("MMMM yyyy")
                    </p>
                </div>
                <ModifyOwnUserForm 
                    userId="@record.UserIDGuid.ToString()" 
                    displayName="@record.Public.Data.DisplayName" 
                    email="@record.Private.Data.Email"
                    bio="@record.Public.Data.Bio" 
                    firstName="@record.Private.Data.FirstName" 
                    lastName="@record.Private.Data.LastName" 
                    postalCode="@record.Private.Data.PostalCode"
                    OnSubmit="HandleModifyUserSubmit"/>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="flex flex-1 items-center justify-center py-12">
            <p class="text-muted-foreground">You must be logged in to view this page. <a href="/login" class="text-primary underline-offset-4 hover:underline">Sign in</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    // TODO: Handle Error Cases and Mapping in both forms
    // TODO: Refresh Token When Either Form Is Sucessfully submitted
    private UserNormalRecord? record { get; set; }

    private string Initials => record?.Public.Data.DisplayName is { Length: > 0 } name
        ? string.Concat(name.Split(' ').Take(2).Select(p => p[0]))
        : "?";

    protected override async Task OnInitializedAsync()
    {
        var token = HttpContextAccessor.HttpContext?.Request.Cookies[AuthClient.CookieName];
        if (string.IsNullOrEmpty(token)) return;
        var res = await authClient.GetOwnUserAsync(token);
        if (res is not null)
            record = res.Record;
    }

    private async Task HandleModifyUserSubmit(ModifyOwnUserRequest req)
    {
        var token = HttpContextAccessor.HttpContext?.Request.Cookies[AuthClient.CookieName];
        if (string.IsNullOrEmpty(token)) return;
        await authClient.ModifyOwnUserAsync(token, req);
    }

    private async Task HandleChangePasswordSubmit(ChangeOwnPasswordRequest req)
    {
        var token = HttpContextAccessor.HttpContext?.Request.Cookies[AuthClient.CookieName];
        if (string.IsNullOrEmpty(token)) return;
        await authClient.ChangeOwnPasswordAsync(token, req);
    }
}
