@page "/subscribe"
@using IT.WebHost.Components.Payments
@inject IT.WebHost.App.Services.SiteSettingsService SiteSettings

<div class="container py-16">
    <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight">Choose a Plan</h1>
        <p class="mt-3 text-lg text-muted-foreground">Support the show and unlock exclusive content.</p>
    </div>
    <div class="flex flex-wrap justify-center gap-6">
        @foreach (var tier in SiteSettings.Settings?.Subscription?.Tiers ?? [])
        {
            <SubscriptionTierCard tier="@tier" />
        }
    </div>
</div>