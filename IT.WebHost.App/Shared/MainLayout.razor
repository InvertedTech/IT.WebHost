@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject IT.WebHost.Core.Services.SiteSettingsService SiteSettings

<div class="relative min-h-screen flex flex-col">
    <BbResponsiveNavProvider>

        <header class="sticky top-0 z-50 w-full border-b bg-background">
            <div class="container flex h-14 items-center justify-between">

                <div class="flex items-center gap-4">
                    <BbResponsiveNavTrigger />
                    <a href="/" class="flex items-center space-x-2">
                        <LucideIcon Name="box" Size="24" class="text-primary" />
                        <span class="font-bold">@SiteSettings.SiteTitle</span>
                    </a>
                </div>

                <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
                    @foreach (var item in navItems)
                    {
                        <NavLink href="@item.Href" Match="item.Match" class="text-foreground/60 hover:text-foreground transition-colors">@item.Text</NavLink>
                    }
                </nav>

                <div class="hidden md:flex items-center gap-2">
                    <AuthorizeView>
                        <Authorized>
                            <BbDropdownMenu>
                                <BbDropdownMenuTrigger>
                                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
                                        <LucideIcon Name="menu" class="h-4 w-4" /> Account
                                    </BbButton>
                                </BbDropdownMenuTrigger>
                                <BbDropdownMenuContent>
                                    <BbDropdownMenuSeparator />
                                    <BbDropdownMenuItem><a href="/profile">Profile</a></BbDropdownMenuItem>
                                    <BbDropdownMenuSeparator />
                                    <BbDropdownMenuItem><a href="/auth/logout">Log out</a></BbDropdownMenuItem>
                                </BbDropdownMenuContent>
                            </BbDropdownMenu>
                        </Authorized>
                        <NotAuthorized>
                            <a href="/login"><BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small">Login</BbButton></a>
                            <a href="/signup"><BbButton Size="ButtonSize.Small">Sign Up</BbButton></a>
                        </NotAuthorized>
                    </AuthorizeView>
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="ToggleDarkMode">
                        @if (isDarkMode) { <LucideIcon Name="sun" Size="20" /> } else { <LucideIcon Name="moon" Size="20" /> }
                    </BbButton>
                </div>

            </div>
        </header>

        <BbResponsiveNavContent>
            <Header>
                <a href="/" class="flex items-center space-x-2">
                    <LucideIcon Name="box" Size="24" class="text-primary" />
                    <span class="font-bold">@SiteSettings.SiteTitle</span>
                </a>
            </Header>
            <ChildContent>
                <nav class="flex flex-col gap-1">
                    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Navigation</p>
                    @foreach (var item in navItems)
                    {
                        <NavLink href="@item.Href" Match="item.Match" class="text-sm font-medium py-2 hover:text-primary transition-colors">@item.Text</NavLink>
                    }
                </nav>
            </ChildContent>
            <Footer>
                <div class="flex flex-col gap-2 pt-4 border-t">
                    <AuthorizeView>
                        <Authorized>
                            <a href="/profile"><BbButton Variant="ButtonVariant.Outline" class="w-full">Profile</BbButton></a>
                            <a href="/auth/logout"><BbButton Variant="ButtonVariant.Ghost" class="w-full">Log out</BbButton></a>
                        </Authorized>
                        <NotAuthorized>
                            <a href="/signup"><BbButton class="w-full">Sign Up</BbButton></a>
                            <a href="/login"><BbButton Variant="ButtonVariant.Outline" class="w-full">Login</BbButton></a>
                        </NotAuthorized>
                    </AuthorizeView>
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="ToggleDarkMode">
                        @if (isDarkMode) { <LucideIcon Name="sun" Size="20" /> } else { <LucideIcon Name="moon" Size="20" /> }
                    </BbButton>
                </div>
            </Footer>
        </BbResponsiveNavContent>

    </BbResponsiveNavProvider>

    <main class="flex-1 flex flex-col">
        @Body
    </main>

    <footer class="border-t py-6 md:py-0">
        <div class="container flex flex-col items-center justify-between gap-4 md:h-14 md:flex-row">
            <p class="text-sm text-muted-foreground flex items-center gap-1">
                Made with <LucideIcon Name="heart" Size="14" class="text-red-500" /> by Inverted Tech
            </p>
        </div>
    </footer>
</div>

<BbToastProvider Position="ToastPosition.BottomRight" />
<BbDialogProvider />
<BbPortalHost />

