@page "/"
@using IT.WebServices.Fragments.Content

<PageTitle>Home</PageTitle>

<div class="space-y-6 max-w-6xl">
    <div class="space-y-2">
        <h1 class="text-3xl font-bold tracking-tight">Content</h1>
        <p class="text-muted-foreground">Browse and manage published content.</p>
    </div>

    @if (content.Any())
    {
        <ContentFeed InitialContent="@content"
                     NextPageOffset="@pageOffsetEnd"
                     PageSize="@((uint)pageSize)"
                     TotalItems="@pageTotalItems"
                     Layout="LayoutEnum.Grid" />
    }
    else
    {
        <div class="flex items-center justify-center py-12">
            <Alert Variant="AlertVariant.Warning">
                <AlertTitle>No Content</AlertTitle>
                <AlertDescription>No content items to display.</AlertDescription>
            </Alert>
        </div>
    }
</div>
