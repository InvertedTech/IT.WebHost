@using Microsoft.AspNetCore.Components.Authorization

<div class="flex items-center justify-between h-16 px-4 md:px-6 border-b">

    <div class="flex items-center gap-4">

        <a href="#" @onclick:preventDefault class="flex items-center gap-2 font-semibold shrink-0">

            <div class="size-7 rounded-lg bg-foreground flex items-center justify-center">

                <LucideIcon Name="layers" Size="14" Class="text-background" />

            </div>

            <span class="text-sm">Acme</span>

        </a>

        <div class="">

            <NavigationMenu>

                <NavigationMenuList>

                    <NavigationMenuItem>

                        <NavigationMenuLink href="/content">Content</NavigationMenuLink>

                    </NavigationMenuItem>

                    <NavigationMenuItem>

                        <NavigationMenuLink href="/members">Members Area</NavigationMenuLink>

                    </NavigationMenuItem>

                    <NavigationMenuItem>

                        <NavigationMenuLink href="/merch">Merch</NavigationMenuLink>

                    </NavigationMenuItem>

                </NavigationMenuList>

            </NavigationMenu>

        </div>

    </div>

    <div class="flex items-center gap-2">

        <div class="hidden md:flex items-center gap-2">

            <AuthorizeView>
                <Authorized>
                    <DropdownMenu>
                        <DropdownMenuTrigger>
                            <Button Variant="ButtonVariant.Outline">Account</Button>
                        </DropdownMenuTrigger>
                        <DropdownMenuContent>
                            <DropdownMenuLabel>My Account</DropdownMenuLabel>
                            <DropdownMenuSeparator />
                            <DropdownMenuItem OnClick="@(() => OnButtonClick("/profile"))">Profile</DropdownMenuItem>
                            <DropdownMenuItem OnClick="@(() => OnButtonClick("/subscribe"))">Subscribe</DropdownMenuItem>
                            <DropdownMenuSeparator />
                            <DropdownMenuItem OnClick="@(() => OnButtonClick("/auth/logout", forceLoad: true))">Logout</DropdownMenuItem>
                        </DropdownMenuContent>
                    </DropdownMenu>
             </Authorized>
             <NotAuthorized>
                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="@(() => OnButtonClick("/login"))">Login</Button>

                    <Button Size="ButtonSize.Small" OnClick="@(() => OnButtonClick("/signup"))">Signup</Button>
             </NotAuthorized>
         </AuthorizeView>

        </div>

        <div class="md:hidden">

            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon">

                <LucideIcon Name="menu" Size="20" />

            </Button>

        </div>

    </div>

</div>

@code {
    [Inject] public NavigationManager navigationManager { get; set; } = null!;

    private void OnButtonClick(string path, bool forceLoad = false)
    {
        navigationManager.NavigateTo(path, forceLoad);
    }
}
