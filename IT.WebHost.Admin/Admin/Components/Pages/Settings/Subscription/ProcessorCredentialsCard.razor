@using IT.WebServices.Fragments.Settings
<div class="settings-card">
    <div class="settings-card-header">
        <div class="settings-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" />
            </svg>
        </div>
        <h3 class="settings-card-title">Processor Credentials</h3>
    </div>

    <div class="settings-card-body cred-body">

        <Accordion Type="AccordionType.Multiple">

            @* Stripe *@
            <AccordionItem Value="stripe">
                <AccordionTrigger>
                    <div class="cred-sub-header">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="5" width="20" height="14" rx="2" />
                            <line x1="2" y1="10" x2="22" y2="10" />
                        </svg>
                        Stripe Configuration
                    </div>
                </AccordionTrigger>
                <AccordionContent>
                    <div class="cred-fields">
                        <div class="cred-fields-row">
                            <Field Label="Account">
                                <Input Value="@Owner.Stripe.Account" Placeholder="acct_1P6XpC..." Disabled="@(!IsEditing)" />
                            </Field>
                            <Field Label="Client ID">
                                <Input Value="@Owner.Stripe.ClientID" Placeholder="ca_F9zL9mPQ..." Disabled="@(!IsEditing)" />
                            </Field>
                        </div>
                        <Field Label="Client Secret">
                            <Input Type="InputType.Password" Value="@Owner.Stripe.ClientSecret" Placeholder="••••••••••••••••" Disabled="@(!IsEditing)" />
                        </Field>
                    </div>
                </AccordionContent>
            </AccordionItem>

            @* PayPal *@
            <AccordionItem Value="paypal">
                <AccordionTrigger>
                    <div class="cred-sub-header">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="3" width="20" height="18" rx="2" />
                            <path d="M8 10h8M8 14h4" />
                        </svg>
                        PayPal Configuration
                    </div>
                </AccordionTrigger>
                <AccordionContent>
                    <div class="cred-fields">
                        <Field Label="Client Secret">
                            <Input Type="InputType.Password" Value="@Owner.Paypal.ClientSecret" Placeholder="••••••••••••••••" Disabled="@(!IsEditing)" />
                        </Field>
                    </div>
                </AccordionContent>
            </AccordionItem>

            @* Fortis *@
            <AccordionItem Value="fortis">
                <AccordionTrigger>
                    <div class="cred-sub-header">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 22v-8.5A2.5 2.5 0 0 1 5.5 11h13A2.5 2.5 0 0 1 21 13.5V22" />
                            <path d="M12 11V2" />
                            <path d="M7 11l5-9 5 9" />
                        </svg>
                        Fortis Configuration
                    </div>
                </AccordionTrigger>
                <AccordionContent>
                    <div class="cred-fields">
                        <div class="cred-fields-row">
                            <Field Label="User ID">
                                <Input Value="@Owner.Fortis.UserID" Placeholder="USR_99281" Disabled="@(!IsEditing)" />
                            </Field>
                            <Field Label="User API Key">
                                <Input Type="InputType.Password" Value="@Owner.Fortis.UserApiKey" Placeholder="••••••••••••••••" Disabled="@(!IsEditing)" />
                            </Field>
                        </div>
                        <div class="cred-fields-row">
                            <Field Label="Location ID">
                                <Input Value="@Owner.Fortis.LocationID" Placeholder="LOC_001" Disabled="@(!IsEditing)" />
                            </Field>
                            <Field Label="Product ID">
                                <Input Value="@Owner.Fortis.ProductID" Placeholder="PROD_SUBS_01" Disabled="@(!IsEditing)" />
                            </Field>
                        </div>
                    </div>
                </AccordionContent>
            </AccordionItem>

            @* Crypto *@
            <AccordionItem Value="crypto">
                <AccordionTrigger>
                    <div class="cred-sub-header">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11.767 19.089c4.924.868 6.14-6.025 1.216-6.894m-1.216 6.894L5.86 18.047m5.908 1.042-.347 1.97m1.563-8.864c4.924.869 6.14-6.025 1.215-6.893m-1.215 6.893-3.94-.694m5.155-6.2L8.29 4.26m5.908 1.042.348-1.97M7.48 20.364l3.126-17.727" />
                        </svg>
                        Crypto Wallet
                    </div>
                </AccordionTrigger>
                <AccordionContent>
                    <div class="cred-fields">
                        <p class="cred-empty">No credentials required for crypto payments.</p>
                    </div>
                </AccordionContent>
            </AccordionItem>

        </Accordion>

    </div>
</div>

<style>
    .cred-sub-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--primary);
    }

    .cred-body {
        padding: 0 0.25rem;
    }

    .cred-fields {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1rem 0.25rem 1.5rem;
    }

    .cred-fields-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .cred-empty {
        font-size: 0.8rem;
        color: var(--muted-foreground);
        margin: 0;
    }
</style>

@code {
    [Parameter, EditorRequired] public SubscriptionOwnerRecord Owner { get; set; } = null!;
    [Parameter] public bool IsEditing { get; set; }
}
