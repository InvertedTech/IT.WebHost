@code {
    [Inject] public PublicSettingsClient PublicSettingsClient { get; set; } = null!;
    [Inject] public SettingsClient SettingsClient { get; set; } = null!;
    [Inject] public IToastService ToastService { get; set; } = null!;

    private bool _shopifyEnabled = false;
    private List<ShopifyStoreConfig> _stores = new();

    private bool _isEditing = false;
    private bool _isSheetOpen = false;
    private ShopifyStoreConfig? _selectedStore = null;
    private string _editInternalStoreId = "";
    private string _editStoreName = "";
    private string _editStoreAdminToken = "";
    private string _editStorefrontDomain = "";
    private List<string> _editCollectionIds = new();

    protected override async Task OnInitializedAsync() => await LoadSettings();

    private async Task LoadSettings()
    {
        var pubData = await PublicSettingsClient.PublicData;
        if (pubData?.Merch?.Shopify is { } shopifyPub)
            _shopifyEnabled = shopifyPub.IsEnabled;

        var ownerData = await SettingsClient.OwnerData;
        if (ownerData?.Merch?.Shopify?.Stores is { Count: > 0 } stores)
            _stores = stores.ToList();
    }

    private void ToggleEdit() => _isEditing = !_isEditing;

    private async Task CancelEdit()
    {
        _isEditing = false;
        await LoadSettings();
    }

    private async Task HandleSave()
    {
        await PersistPublic();
        await PersistStores();
        _isEditing = false;
    }

    private async Task PersistPublic()
    {
        var pubData = await PublicSettingsClient.PublicData;
        var merch = (pubData?.Merch ?? new MerchPublicSettings()).Clone();
        merch.Shopify ??= new ShopifyPublicSettings();
        merch.Shopify.IsEnabled = _shopifyEnabled;

        var error = await SettingsClient.ModifyMerchPublicSettings(new ModifyMerchPublicSettingsRequest { Data = merch });
        PublicSettingsClient.InvalidateCache();

        if (error is not null && error.Reason != APIErrorReason.ErrorReasonNoError)
            ToastService.Error(!string.IsNullOrEmpty(error.Message) ? error.Message : error.Reason.ToString());
    }

    private async Task PersistStores()
    {
        var owner = await SettingsClient.OwnerData;
        var merch = (owner?.Merch ?? new MerchOwnerSettings()).Clone();
        merch.Shopify ??= new ShopifyOwnerSettings();
        merch.Shopify.Stores.Clear();
        merch.Shopify.Stores.AddRange(_stores);

        var error = await SettingsClient.ModifyMerchOwnerSettings(new ModifyMerchOwnerSettingsRequest { Data = merch });

        if (error is null || error.Reason == APIErrorReason.ErrorReasonNoError)
            ToastService.Success("Merch settings saved successfully.");
        else
            ToastService.Error(!string.IsNullOrEmpty(error.Message) ? error.Message : error.Reason.ToString());
    }

    private void OpenCreateSheet()
    {
        _selectedStore = null;
        _editInternalStoreId = "";
        _editStoreName = "";
        _editStoreAdminToken = "";
        _editStorefrontDomain = "";
        _editCollectionIds = new();
        _isSheetOpen = true;
    }

    private void OpenEditSheet(ShopifyStoreConfig store)
    {
        _selectedStore = store;
        _editInternalStoreId = store.InternalStoreID ?? "";
        _editStoreName = store.StoreName ?? "";
        _editStoreAdminToken = store.StoreAdminToken ?? "";
        _editStorefrontDomain = store.StorefrontDomain ?? "";
        _editCollectionIds = store.CollectionIds.ToList();
        _isSheetOpen = true;
    }

    private void CloseSheet()
    {
        _selectedStore = null;
        _isSheetOpen = false;
    }

    private void SaveStoreToList()
    {
        var collectionIds = _editCollectionIds.Where(id => !string.IsNullOrWhiteSpace(id)).ToList();

        if (_selectedStore is not null)
        {
            _selectedStore.StoreName = _editStoreName;
            _selectedStore.StoreAdminToken = _editStoreAdminToken;
            _selectedStore.StorefrontDomain = _editStorefrontDomain;
            _selectedStore.CollectionIds.Clear();
            _selectedStore.CollectionIds.AddRange(collectionIds);
        }
        else
        {
            var newStore = new ShopifyStoreConfig
            {
                InternalStoreID = Guid.NewGuid().ToString(),
                StoreName = _editStoreName,
                StoreAdminToken = _editStoreAdminToken,
                StorefrontDomain = _editStorefrontDomain,
            };
            newStore.CollectionIds.AddRange(collectionIds);
            _stores.Add(newStore);
        }

        CloseSheet();
    }

    private void AddCollectionId() => _editCollectionIds.Add("");

    private void RemoveCollectionId(int index)
    {
        if (index >= 0 && index < _editCollectionIds.Count)
            _editCollectionIds.RemoveAt(index);
    }

    private void OnSyncGlobal() { }

    private static string GetAvatarColor(string? name)
    {
        var colors = new[] { "#7c3aed", "#2563eb", "#059669", "#d97706", "#dc2626", "#db2777" };
        if (string.IsNullOrEmpty(name)) return colors[0];
        return colors[Math.Abs(name.GetHashCode()) % colors.Length];
    }
}