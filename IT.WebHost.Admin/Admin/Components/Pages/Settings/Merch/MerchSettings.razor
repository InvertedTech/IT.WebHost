@page "/settings/merch"
@using IT.WebServices.Clients.Settings
@using IT.WebServices.Fragments
@using IT.WebServices.Fragments.Merch
@using IT.WebServices.Fragments.Settings
@using IT.WebServices.Fragments.Merch.Shopify
@rendermode InteractiveServer

<div class="merch-page">

    <div class="merch-page-header">
        <div>
            <h1 class="merch-page-title">Merch Configuration</h1>
            <p class="merch-page-subtitle">Global commerce integration and multi-store orchestration.</p>
        </div>
        <div class="merch-page-actions">
            <Button Variant="ButtonVariant.Outline" OnClick="OnSyncGlobal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem"><path d="M21.5 2v6h-6" /><path d="M2.5 22v-6h6" /><path d="M22 11.5A10 10 0 0 1 3.2 7.2" /><path d="M2 12.5A10 10 0 0 0 20.8 16.8" /></svg>
                Sync Global
            </Button>
            <Button Variant="ButtonVariant.Default" OnClick="OpenCreateSheet">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                New Store
            </Button>
        </div>
    </div>

    <div class="merch-grid">

        <div class="merch-card">
            <div class="merch-card-header">
                <span class="merch-card-title">General Settings</span>
                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="ToggleEdit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                </Button>
            </div>
            <div class="merch-card-body">
                <div class="provider-row">
                    <div class="provider-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                    </div>
                    <div class="provider-text">
                        <span class="provider-label">IsEnabled</span>
                        <span class="provider-desc">Global Shopify integration</span>
                    </div>
                    <Switch @bind-Checked="_shopifyEnabled" Disabled="@(!_isEditing)" />
                </div>

                <div class="merch-info-box">
                    <p class="merch-info-text">Enabling the global integration status allows the platform to fetch real-time product data and synchronize inventory across all configured Shopify instances.</p>
                </div>
            </div>
        </div>

        <div class="merch-card">
            <div class="merch-card-header">
                <span class="merch-card-title">Shopify Stores</span>
                <span class="merch-store-count">@_stores.Count Connected Store@(_stores.Count == 1 ? "" : "s")</span>
            </div>

            <div class="store-table-head">
                <span>STORENAME</span>
                <span>STOREFRONTDOMAIN</span>
                <span>ACTIONS</span>
            </div>

            @if (_stores.Count == 0)
            {
                <div class="store-empty">No stores configured yet.</div>
            }
            else
            {
                @foreach (var store in _stores)
                {
                    var capturedStore = store;
                    var initial = string.IsNullOrEmpty(store.StoreName) ? "?" : store.StoreName[0].ToString().ToUpper();
                    var avatarColor = GetAvatarColor(store.StoreName);

                    <div class="store-row">
                        <div class="store-name-cell">
                            <div class="store-avatar" style="background:@avatarColor">@initial</div>
                            <span class="store-name">@store.StoreName</span>
                        </div>
                        <a href="https://@store.StorefrontDomain" class="store-domain" target="_blank">@store.StorefrontDomain</a>
                        <div class="store-actions">
                            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="() => OpenEditSheet(capturedStore)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                            </Button>
                        </div>
                    </div>
                }
            }

@*             <div class="store-footer">
                <button class="store-logs-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6" /><path d="M2.5 22v-6h6" /><path d="M22 11.5A10 10 0 0 1 3.2 7.2" /><path d="M2 12.5A10 10 0 0 0 20.8 16.8" /></svg>
                    View Integration Logs
                </button>
            </div> *@
            @*TODO: Add Provider Credentials Thing*@
        </div>

    </div>

</div>

@if (_isEditing)
{
    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSave" />
}

<Sheet @bind-Open="_isSheetOpen">
    <SheetContent Class="flex flex-col gap-6">
        <SheetHeader>
            <SheetTitle>@(_selectedStore is not null ? "Modify Store" : "Create New Store")</SheetTitle>
        </SheetHeader>
        <div class="space-y-4">
            @if (_selectedStore is not null)
            {
                <Field>
                    <FieldLabel For="internal-store-id">Internal Store ID</FieldLabel>
                    <FieldContent>
                        <Input Id="internal-store-id" Type="InputType.Text" Disabled="true" @bind-Value="_editInternalStoreId" />
                    </FieldContent>
                </Field>
            }
            <Field>
                <FieldLabel For="store-name">Store Name</FieldLabel>
                <FieldContent>
                    <Input Id="store-name" Type="InputType.Text" Placeholder="Enter The Name Of Your Store" @bind-Value="_editStoreName" />
                </FieldContent>
            </Field>
            <Field>
                <FieldLabel For="admin-token">Admin Token</FieldLabel>
                <FieldContent>
                    <Input Id="admin-token" Type="InputType.Password" Placeholder="Your Shopify Admin API Token" @bind-Value="_editStoreAdminToken" />
                </FieldContent>
            </Field>
            <Field>
                <FieldLabel For="storefront-domain">Storefront Domain</FieldLabel>
                <FieldContent>
                    <Input Id="storefront-domain" Type="InputType.Text" Placeholder="e.g. your-store.myshopify.com" @bind-Value="_editStorefrontDomain" />
                </FieldContent>
            </Field>
            <Field>
                <FieldLabel>Collection IDs</FieldLabel>
                <FieldContent Class="space-y-3">
                    @for (var i = 0; i < _editCollectionIds.Count; i++)
                    {
                        var index = i;
                        <div class="flex items-center gap-3">
                            <Input Class="flex-1" Type="InputType.Text" Placeholder="gid://shopify/Collection/123456789" @bind-Value="_editCollectionIds[index]" />
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="() => RemoveCollectionId(index)">Remove</Button>
                        </div>
                    }
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="AddCollectionId">Add Collection ID</Button>
                </FieldContent>
            </Field>
        </div>
        <SheetFooter Class="gap-2 sm:justify-end">
            <Button Variant="ButtonVariant.Outline" OnClick="CloseSheet">Close</Button>
            <Button OnClick="SaveStoreToList">Save</Button>
        </SheetFooter>
    </SheetContent>
</Sheet>

<style>
