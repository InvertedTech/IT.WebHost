        flex-direction: column;
        gap: 1.5rem;
    }

    .merch-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }

    .merch-page-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0 0 0.25rem;
    }

    .merch-page-subtitle {
        font-size: 0.85rem;
        color: var(--muted-foreground);
        margin: 0;
    }

    .merch-page-actions {
        display: flex;
        gap: 0.75rem;
        flex-shrink: 0;
    }

    .merch-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.5rem;
