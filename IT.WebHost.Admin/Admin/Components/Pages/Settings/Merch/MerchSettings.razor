    .merch-card {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--card);
        overflow: hidden;
    }

    .merch-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
    }

    .merch-card-title {
        font-size: 0.95rem;
        font-weight: 600;
    }

    .merch-store-count {
        font-size: 0.78rem;
        color: var(--muted-foreground);
    }

    .merch-card-body {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .provider-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--muted);
    }

    .provider-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius);
        background: var(--background);
        display: flex;
        align-items: center;
