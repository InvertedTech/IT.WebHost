@using Admin
@using BlazorBlueprint.Primitives.Services
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <script type="importmap"></script>
    <link href="~/css/theme.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/_content/BlazorBlueprint.Components/blazorblueprint.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" asp-append-version="true" />
    <base href="@Url.Content("~/")" />
    <component type="typeof(Microsoft.AspNetCore.Components.Web.HeadOutlet)"
               render-mode="ServerPrerendered" />
</head>
<body class="font-sans antialiased bg-background text-foreground">
    <div class="flex h-screen overflow-hidden">
        <div style="width: var(--sidebar-width); flex-shrink: 0; overflow: hidden;">
            <component type="typeof(IT.WebHost.Admin.Components.AdminSidebar)"
                       render-mode="Server" />
        </div>
        <div class="flex flex-col flex-1 min-w-0 overflow-auto">
            <header class="flex h-14 shrink-0 items-center gap-4 border-b px-6">
                <h1 class="text-lg font-semibold">@ViewData["Title"]</h1>
            </header>
            <main class="flex-1 p-4 lg:p-6">
                @RenderBody()
            </main>
        </div>
    </div>
    <component type="typeof(BbPortalHost)" render-mode="ServerPrerendered" />
    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
