@using Core.Services
@inject TemplateService templateService

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/components.css"]" />

    <!-- Base color themes — in production, include only the one you use -->
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/zinc.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/slate.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/gray.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/neutral.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/stone.css"]" />

    <!-- Primary color themes — in production, include only the one you use -->
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/red.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/rose.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/orange.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/amber.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/yellow.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/lime.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/green.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/emerald.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/teal.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/cyan.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/sky.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/blue.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/indigo.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/violet.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/purple.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/fuchsia.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/primary/pink.css"]" />
    <!-- New base colors (v4.0.0): Luma, Mist, Mauve, Taupe, Olive -->
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/luma.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/mist.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/mauve.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/taupe.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/base/olive.css"]" />

    <!-- Style variants (v4.0.0) — include for ThemeSwitcher runtime switching -->
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/styles/vega.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/styles/nova.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/styles/maia.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/styles/lyra.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/styles/mira.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/styles/luma.css"]" />

    <!-- Radius presets (v4.0.0) -->
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/radius/none.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/radius/small.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/radius/large.css"]" />

    <!-- Font presets (v4.0.0) — CSS variable definitions only; load font faces (Google Fonts etc.) separately -->
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/fonts/inter.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/fonts/geist.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/fonts/calsans.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/fonts/dmsans.css"]" />
    <link rel="stylesheet" href="@Assets["_content/NeoUI.Blazor/css/themes/fonts/plusjakarta.css"]" />

    <!-- Site theme override - must load after NeoUI themes -->
    <link id="theme-css" rel="stylesheet" href="styles/themes/@(templateService.TemplateFile).css" />
<ImportMap />
    <link rel="icon" type="image/png" href="@Assets["favicon.png"]" />
    <HeadOutlet @rendermode="InteractiveServer" />

    <!-- Theme management JavaScript -->
    <script src="@Assets["_content/NeoUI.Blazor/js/theme.js"]"></script>
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.setTheme = (name) => { const l = document.getElementById('theme-css'); if (l) l.href = `/styles/themes/${name}.css`; };
    </script>
    <AppLoader />
    <script>
        // Uncomment to enable AppLoader
        /* setTimeout(function() {
            if (window.AppLoader) {
                window.AppLoader.init();
            }
        }, 0); */
    </script>
</body>

</html>
