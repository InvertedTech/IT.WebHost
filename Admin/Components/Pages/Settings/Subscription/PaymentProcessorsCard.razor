@using IT.WebServices.Fragments.Settings

<div class="settings-card">
    <div class="settings-card-header">
        <div class="settings-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
        </div>
        <h3 class="settings-card-title">Payment Processors</h3>
    </div>

    <div class="settings-card-body">
        <div class="processor-list">

            <div class="processor-row">
                <div class="processor-icon processor-icon--stripe">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
                </div>
                <div class="processor-info">
                    <span class="processor-name">Stripe</span>
                    <span class="processor-status @(Public.Stripe.Enabled ? "processor-status--active" : "processor-status--disabled")">
                        @(Public.Stripe.Enabled ? "ACTIVE" : "DISABLED")
                    </span>
                </div>
                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="processor-settings-btn"
                        OnClick="OnStripeSettings">
                </Button>
                <Switch Checked="@Public.Stripe.Enabled" Disabled="@(!IsEditing)" />
            </div>

            <div class="processor-row">
                <div class="processor-icon processor-icon--paypal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2" /><path d="M8 10h8M8 14h4" /></svg>
                </div>
                <div class="processor-info">
                    <span class="processor-name">PayPal</span>
                    <span class="processor-status @(Public.Paypal.Enabled ? "processor-status--active" : "processor-status--disabled")">
                        @(Public.Paypal.Enabled ? "ACTIVE" : "DISABLED")
                    </span>
                </div>
                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="processor-settings-btn"
                        OnClick="OnPaypalSettings">
                </Button>
                <Switch Checked="@Public.Paypal.Enabled" Disabled="@(!IsEditing)" />
            </div>

            <div class="processor-row">
                <div class="processor-icon processor-icon--fortis">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22v-8.5A2.5 2.5 0 0 1 5.5 11h13A2.5 2.5 0 0 1 21 13.5V22" /><path d="M12 11V2" /><path d="M7 11l5-9 5 9" /></svg>
                </div>
                <div class="processor-info">
                    <span class="processor-name">Fortis</span>
                    <span class="processor-status @(Public.Fortis.Enabled ? "processor-status--active" : "processor-status--disabled")">
                        @(Public.Fortis.Enabled ? "ACTIVE" : "DISABLED")
                    </span>
                </div>
                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="processor-settings-btn"
                        OnClick="OnFortisSettings">
                </Button>
                <Switch Checked="@Public.Fortis.Enabled" Disabled="@(!IsEditing)" />
            </div>

            <div class="processor-row">
                <div class="processor-icon processor-icon--crypto">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.767 19.089c4.924.868 6.14-6.025 1.216-6.894m-1.216 6.894L5.86 18.047m5.908 1.042-.347 1.97m1.563-8.864c4.924.869 6.14-6.025 1.215-6.893m-1.215 6.893-3.94-.694m5.155-6.2L8.29 4.26m5.908 1.042.348-1.97M7.48 20.364l3.126-17.727" /></svg>
                </div>
                <div class="processor-info">
                    <span class="processor-name">Crypto</span>
                    <span class="processor-status @(Public.Crypto.Enabled ? "processor-status--active" : "processor-status--disabled")">
                        @(Public.Crypto.Enabled ? "ACTIVE" : "DISABLED")
                    </span>
                </div>
                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="processor-settings-btn"
                        OnClick="OnCryptoSettings">
                </Button>
                <Switch Checked="@Public.Crypto.Enabled" Disabled="@(!IsEditing)" />
            </div>

        </div>
    </div>
</div>

<style>
    .processor-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .processor-row {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--border);
    }

        .processor-row:last-child {
            border-bottom: none;
        }

    .processor-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: var(--radius);
        flex-shrink: 0;
        color: #fff;
    }

    .processor-icon--stripe { background: #5469d4; }
    .processor-icon--paypal { background: #002f86; }
    .processor-icon--fortis { background: #6b7280; }
    .processor-icon--crypto { background: #f7931a; }

    .processor-info {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        flex: 1;
    }

    .processor-name {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--foreground);
    }

    .processor-status {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.07em;
    }

    .processor-status--active { color: #22c55e; }
    .processor-status--disabled { color: var(--muted-foreground); }

    .processor-settings-btn {
        color: var(--muted-foreground);
    }
</style>

@code {
    [Parameter, EditorRequired] public SubscriptionPublicRecord Public { get; set; } = null!;
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public EventCallback OnStripeSettings { get; set; }
    [Parameter] public EventCallback OnPaypalSettings { get; set; }
    [Parameter] public EventCallback OnFortisSettings { get; set; }
    [Parameter] public EventCallback OnCryptoSettings { get; set; }
}
