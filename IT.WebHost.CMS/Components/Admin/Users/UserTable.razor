@namespace IT.WebHost.CMS.Components.Admin.Users
@using IT.WebServices.Fragments.Authentication

<BbDataTable TData="UserSearchRecord" Data="@Users" InitialPageSize="@PageSize" ShowPagination="false" ShowToolbar="false" IsLoading="@IsLoading" Class="bb-table-fix">
    <Columns>
        <BbDataTableColumn TData="UserSearchRecord" TValue="string" Property="(u => u.FirstName)" Header="First Name" />
        <BbDataTableColumn TData="UserSearchRecord" TValue="string" Property="(u => u.LastName)" Header="Last Name" />
        <BbDataTableColumn TData="UserSearchRecord" TValue="string" Property="(u => u.Email)" Header="Email" />
        <BbDataTableColumn TData="UserSearchRecord" TValue="string" Property="(u => u.DisplayName)" Header="Display Name" />
        <BbDataTableColumn TData="UserSearchRecord" TValue="string" Property="(u => u.UserName)" Header="User Name" />
    </Columns>
</BbDataTable>

@code {
    [Parameter] public IEnumerable<UserSearchRecord> Users { get; set; } = [];
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public bool IsLoading { get; set; }
}
