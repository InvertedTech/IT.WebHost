@namespace IT.WebHost.CMS.Components.Admin.Users
@using IT.WebServices.Fragments.Authentication
@inject NavigationManager Nav

<BbDataGrid TData="UserSearchRecord" Items="@Users" InitialPageSize="@PageSize" ShowPagination="false" IsLoading="@IsLoading" Class="bb-table-fix cursor-pointer"
            OnRowClick="@(u => Nav.NavigateTo($"/admin/users/{u.UserID}"))">
    <Columns>
        <BbDataGridPropertyColumn TData="UserSearchRecord" TProp="string" Property="(u => u.FirstName)" Title="First Name" />
        <BbDataGridPropertyColumn TData="UserSearchRecord" TProp="string" Property="(u => u.LastName)" Title="Last Name" />
        <BbDataGridPropertyColumn TData="UserSearchRecord" TProp="string" Property="(u => u.Email)" />
        <BbDataGridPropertyColumn TData="UserSearchRecord" TProp="string" Property="(u => u.DisplayName)" Title="Display Name" />
        <BbDataGridPropertyColumn TData="UserSearchRecord" TProp="string" Property="(u => u.UserName)" Title="User Name" />
    </Columns>
</BbDataGrid>

@code {
    [Parameter] public IEnumerable<UserSearchRecord> Users { get; set; } = [];
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public bool IsLoading { get; set; }
}
