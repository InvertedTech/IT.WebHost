@namespace IT.WebHost.CMS.Components.Admin.Settings
@using IT.WebHost.CMS.Components.Admin.Forms
@using IT.WebHost.Components.Forms
@using IT.WebServices.Fragments.Settings

<BbEmpty Title="No Categories"
         Description="Get started by creating a category">
    <Icon>
        <LucideIcon Name="folder" class="h-12 w-12" />
    </Icon>
    <ChildContent>
        <FormSheet TriggerText="Add Category"
                   Title="Create a Category"
                   Description="Fill in the details below to create a new category.">
            <Body>
                <CreateCategoryForm OnSubmit="OnSubmit" />
            </Body>
        </FormSheet>
    </ChildContent>
</BbEmpty>

@code {
    [Parameter] public EventCallback<CategoryRecord> OnSubmit { get; set; }
}
