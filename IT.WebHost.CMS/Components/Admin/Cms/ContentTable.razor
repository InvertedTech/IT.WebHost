@namespace IT.WebHost.CMS.Components.Admin.Cms
@using IT.WebServices.Fragments.Content
@inject NavigationManager Nav

<BbDataGrid TData="ContentListRecord" Items="@Content" InitialPageSize="@PageSize" ShowPagination="false" IsLoading="@IsLoading" Class="bb-table-fix cursor-pointer"
            OnRowClick="@(c => Nav.NavigateTo($"/admin/content/{c.ContentID}"))">
    <Columns>
        <BbDataGridPropertyColumn TData="ContentListRecord" TProp="string" Property="(c => c.Title)" />
        <BbDataGridPropertyColumn TData="ContentListRecord" TProp="string" Property="(c => c.Author)" />
        <BbDataGridPropertyColumn TData="ContentListRecord" TProp="uint" Property="(c => c.SubscriptionLevel)" Title="Level" />
        <BbDataGridPropertyColumn TData="ContentListRecord" TProp="DateTime?" Property="(c => c.PublishOnUTC.ToDateTime())" Title="Publish On" />
        <BbDataGridPropertyColumn TData="ContentListRecord" TProp="DateTime" Property="(c => c.CreatedOnUTC.ToDateTime())" Title="Created On" />
    </Columns>
</BbDataGrid>

@code {
    [Parameter] public IEnumerable<ContentListRecord> Content { get; set; } = new List<ContentListRecord>();
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public bool IsLoading { get; set; }
}
