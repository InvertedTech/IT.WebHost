@page "/admin/settings/cms/categories"
@using IT.WebHost.Components.Forms
@layout AdminLayout

<PageTitle>Categories</PageTitle>

<div class="space-y-6">
        <div class="flex items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Categories</h1>
            <p class="text-sm text-muted-foreground mt-0.5">Manage your content categories</p>
        </div>
        <div class="flex items-center gap-2">
            @if (_isEditing && categories.Any())
            {
                <FormSheet TriggerText="Add Category"
                           Title="Create a Category"
                           Description="Fill in the details below to create a new category.">
                    <Body>
                                <CreateCategoryForm ParentCategories="@categories"
                                    OnSubmit="SaveCategoriesAsync" />
                    </Body>
                </FormSheet>
            }
            @if (!_isEditing)
            {
                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit">
                    <LucideIcon Name="pencil" class="h-4 w-4 mr-1.5" />
                    Edit
                </BbButton>
            }
        </div>
    </div>
    @* Category list *@
    @if (categories.Any())
    {
        <div class="flex flex-col gap-2 @(!_isEditing ? "pointer-events-none opacity-60" : "")">
            @foreach (var category in categories)
            {
                <CMSCategory Category="@category" />
            }
        </div>
    }
    else
    {
        <div class="@(!_isEditing ? "pointer-events-none opacity-60" : "")">
            <EmptyCategoryList OnSubmit="SaveCategoriesAsync" />
        </div>
    }
</div>
