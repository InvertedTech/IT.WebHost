@page "/admin/settings/comments/general"
@layout AdminLayout
@using IT.WebServices.Fragments.Comment
@using IT.WebHost.Components.Forms

<PageTitle>Comments - General</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold">General</h1>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit" Disabled="_isEditing">Edit</BbButton>
    </div>

    <BbCard>
        <BbCardContent Class="flex items-center justify-between p-6">
            <div class="space-y-1">
                <p class="text-sm font-medium">Allow Links</p>
                <p class="text-sm text-muted-foreground">Permit hyperlinks in comment text.</p>
            </div>
            <BbSwitch @bind-Checked="_allowLinks" Disabled="!_isEditing" />
        </BbCardContent>
    </BbCard>

    <BbCard>
        <BbCardContent Class="flex items-center justify-between p-6">
            <div class="space-y-1">
                <p class="text-sm font-medium">Explicit Mode</p>
                <p class="text-sm text-muted-foreground">Enable explicit content warnings on comments.</p>
            </div>
            <BbSwitch @bind-Checked="_explicitModeEnabled" Disabled="!_isEditing" />
        </BbCardContent>
    </BbCard>

    <BbFormSection Title="Default Order"
                   Description="How comments are sorted by default">
        <BbFormFieldSelect TValue="CommentOrder"
                           @bind-Value="_defaultOrder"
                           Label="Order"
                           Disabled="!_isEditing"
                           DisplayTextSelector="@(v => v switch {
                               CommentOrder.Liked  => "Most Liked",
                               CommentOrder.Older  => "Oldest First",
                               CommentOrder.Newest => "Newest First",
                               _ => v.ToString()
                           })">
            <BbSelectItem Value="@(CommentOrder.Liked)"  Text="Most Liked" />
            <BbSelectItem Value="@(CommentOrder.Older)"  Text="Oldest First" />
            <BbSelectItem Value="@(CommentOrder.Newest)" Text="Newest First" />
        </BbFormFieldSelect>
    </BbFormSection>

    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSubmit" />
</div>
