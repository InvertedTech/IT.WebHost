@page "/admin/settings/comments/moderation"
@layout AdminLayout
@using IT.WebHost.Components.Forms
<PageTitle>Comments - Moderation</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold">Moderation</h1>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit" Disabled="_isEditing">Edit</BbButton>
    </div>

    <BbFormSection Title="Blacklist"
                   Description="Blocked words or phrases — comments containing these will be rejected">

        @if (_blackList.Count == 0)
        {
            <p class="text-sm text-muted-foreground">No entries.</p>
        }

        @for (var i = 0; i < _blackList.Count; i++)
        {
            var idx = i;
            <div class="flex items-center gap-2 mb-2">
                <BbFormFieldInput TValue="string"
                                  Value="@_blackList[idx]"
                                  ValueChanged="@(v => _blackList[idx] = v ?? string.Empty)"
                                  Label=""
                                  Disabled="!_isEditing" />
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="@(_ => RemoveEntry(idx))" Disabled="!_isEditing">
                    Remove
                </BbButton>
            </div>
        }

        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="@(_ => AddEntry())" Disabled="!_isEditing">
            + Add Entry
        </BbButton>
    </BbFormSection>

    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSubmit" />
</div>
