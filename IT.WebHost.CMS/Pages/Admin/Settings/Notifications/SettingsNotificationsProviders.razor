@page "/admin/settings/notifications/providers"
@layout AdminLayout
@using IT.WebServices.Fragments.Notification
@using IT.WebHost.CMS.Components.Admin.Forms
@using IT.WebHost.Components.Forms

<PageTitle>Notification Providers</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold">Providers</h1>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit" Disabled="_isEditing">Edit</BbButton>
    </div>

    <BbCard>
        <BbCardContent Class="flex items-center justify-between p-6">
            <div class="space-y-1">
                <p class="text-sm font-medium">Sendgrid</p>
                <p class="text-sm text-muted-foreground">Send transactional emails via Sendgrid.</p>
            </div>
            <BbSwitch @bind-Checked="_sendgridEnabled" Disabled="!_isEditing" />
        </BbCardContent>
    </BbCard>

    @if (_sendgridEnabled)
    {
        <div class="@(!_isEditing ? "pointer-events-none opacity-60" : "")">
            <SendgridSettingsForm Data="@_sendgridSettings" OnSubmit="HandleSendgridSubmit" />
        </div>
    }

    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSave" />
</div>
