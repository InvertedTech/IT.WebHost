@page "/admin/settings/personalization/branding"
@layout AdminLayout
@using IT.WebHost.Components.Forms
<PageTitle>Branding</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold">Branding</h1>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit" Disabled="_isEditing">Edit</BbButton>
    </div>

    <BbFormSection Title="Site Identity"
                   Description="Basic information shown in the browser and search results">
        <BbFormFieldInput TValue="string"
                          @bind-Value="_title"
                          Label="Site Title"
                          Disabled="!_isEditing"
                          HelperText="The name of your site" />
        <BbFormFieldTextarea @bind-Value="_metaDescription"
                             Label="Meta Description"
                             Disabled="!_isEditing"
                             HelperText="A short description used by search engines (150–160 characters recommended)" />
    </BbFormSection>

    <BbFormSection Title="Images"
                   Description="Asset IDs for your site's profile and header images">
        <BbFormFieldInput TValue="string"
                          @bind-Value="_profileImageAssetId"
                          Label="Profile Image Asset ID"
                          Disabled="!_isEditing"
                          HelperText="Asset ID of the profile/logo image" />
        <BbFormFieldInput TValue="string"
                          @bind-Value="_headerImageAssetId"
                          Label="Header Image Asset ID"
                          Disabled="!_isEditing"
                          HelperText="Asset ID of the site header image" />
    </BbFormSection>

    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSubmit" />
</div>
