@page "/admin/settings/personalization/theme"
@layout AdminLayout
@using IT.WebHost.Components.Forms
<PageTitle>Theme</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold">Theme</h1>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit" Disabled="_isEditing">Edit</BbButton>
    </div>

    <BbCard>
        <BbCardContent Class="flex items-center justify-between p-6">
            <div class="space-y-1">
                <p class="text-sm font-medium">Dark Mode</p>
                <p class="text-sm text-muted-foreground">Default new visitors to dark mode.</p>
            </div>
            <BbSwitch @bind-Checked="_defaultToDarkMode" Disabled="!_isEditing" />
        </BbCardContent>
    </BbCard>

    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSubmit" />
</div>
