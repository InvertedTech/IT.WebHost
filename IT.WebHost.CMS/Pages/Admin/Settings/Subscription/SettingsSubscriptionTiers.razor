@page "/admin/settings/subscription/tiers"
@layout AdminLayout
@using IT.WebHost.CMS.Components.Admin.Forms
@using IT.WebHost.Components.Forms

<PageTitle>Subscription Tiers</PageTitle>

<div class="space-y-6">

    @* Header *@
    <div class="flex items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Tiers</h1>
            <p class="text-sm text-muted-foreground mt-0.5">Define subscription tiers for your subscribers</p>
        </div>
        @if (!_isEditing)
        {
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit">
                <LucideIcon Name="pencil" class="h-4 w-4 mr-1.5" />
                Edit
            </BbButton>
        }
    </div>

    <div class="@(!_isEditing ? "pointer-events-none opacity-60" : "")">
        <SubscriptionTierForm Data="@_data" OnSubmit="HandleSubmit" />
    </div>

</div>

<SaveChangesBar IsShown="@_isEditing"
                OnDiscard="CancelEdit"
                OnSave="HandleSave"
                SaveButtonLabel="Done" />
