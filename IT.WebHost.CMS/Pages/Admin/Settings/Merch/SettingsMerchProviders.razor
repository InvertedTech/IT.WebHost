@page "/admin/settings/merch/providers"
@layout AdminLayout
@using IT.WebServices.Fragments.Merch.Shopify
@using IT.WebHost.CMS.Components.Admin.Forms
@using IT.WebHost.Components.Forms

<PageTitle>Merch Providers</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold">Providers</h1>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartEdit" Disabled="_isEditing">Edit</BbButton>
    </div>

    <BbCard>
        <BbCardContent Class="flex items-center justify-between p-6">
            <div class="space-y-1">
                <p class="text-sm font-medium">Shopify</p>
                <p class="text-sm text-muted-foreground">Sync products and collections from your Shopify storefront.</p>
            </div>
            <BbSwitch @bind-Checked="_shopifyEnabled" Disabled="!_isEditing" />
        </BbCardContent>
    </BbCard>

    @if (_shopifyEnabled)
    {
        <div class="@(!_isEditing ? "pointer-events-none opacity-60" : "")">
            <ShopifyStorefrontForm Data="@_shopifySettings" OnSubmit="HandleShopifySubmit" />
        </div>
    }

    <SaveChangesBar IsShown="_isEditing" OnDiscard="CancelEdit" OnSave="HandleSave" />
</div>
