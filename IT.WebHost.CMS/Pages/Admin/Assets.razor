@page "/admin/assets"
@using IT.WebHost.Components.Content
@using IT.WebHost.Components.Forms.Fields
@using IT.WebServices.Fragments.Content
@layout AdminLayout

<PageTitle>Assets</PageTitle>

<div class="space-y-6">

    @* Header *@
    <div class="flex items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Assets</h1>
            <p class="text-sm text-muted-foreground mt-0.5">
                @if (_isLoading)
                {
                    <span>Loading…</span>
                }
                else
                {
                    <span>@PageTotalItems.ToString("N0") image@(PageTotalItems == 1 ? "" : "s")</span>
                }
            </p>
        </div>
        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small"
                  OnClick='() => Nav.NavigateTo("/admin/assets/create/image")'>
            <LucideIcon Name="upload" class="h-4 w-4 mr-1.5" />
            Upload Image
        </BbButton>
    </div>

    @* Grid *@
    <BbCard>
        <BbCardContent class="p-4">
            @if (_isLoading)
            {
                <div class="flex items-center justify-center h-48">
                    <div class="flex flex-col items-center gap-3 text-muted-foreground">
                        <LucideIcon Name="loader-circle" class="h-8 w-8 animate-spin" />
                        <span class="text-sm">Loading assets…</span>
                    </div>
                </div>
            }
            else if (!AssetRecords.Any())
            {
                <BbEmpty Title="No assets found"
                         Description="Upload an image to get started.">
                    <Icon>
                        <LucideIcon Name="image" class="h-12 w-12" />
                    </Icon>
                </BbEmpty>
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
                    @foreach (var asset in AssetRecords)
                    {
                        switch (asset.AssetType)
                        {
                            case AssetType.AssetImage:
                                <div class="rounded-lg overflow-hidden border bg-muted hover:ring-2 hover:ring-primary/50 transition-all cursor-pointer">
                                    <FeaturedImage AssetId="@asset.AssetID" Title="@asset.Title" />
                                </div>
                                break;
                        }
                    }
                </div>
            }
        </BbCardContent>
    </BbCard>

    @* Pagination *@
    @if (PageTotalItems > PageSizeParsed)
    {
        <div class="flex items-center justify-between text-sm text-muted-foreground">
            <span>Page @((PageOffsetParsed / PageSizeParsed) + 1) of @((uint)Math.Ceiling((double)PageTotalItems / PageSizeParsed))</span>
            <Pagination PageOffset="PageOffsetParsed"
                        PageSize="PageSizeParsed"
                        PageTotalItems="PageTotalItems"
                        BaseUrl="@BaseUrl" />
        </div>
    }

</div>
