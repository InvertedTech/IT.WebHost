@page "/admin/users"
@layout AdminLayout
@using IT.WebHost.Components.Forms

<PageTitle>Users</PageTitle>

<div class="space-y-6">

    @* Header *@
    <div class="flex items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Users</h1>
            <p class="text-sm text-muted-foreground mt-0.5">
                @if (_isLoading)
                {
                    <span>Loading…</span>
                }
                else
                {
                    <span>@PageTotalItems.ToString("N0") user@(PageTotalItems == 1 ? "" : "s")</span>
                }
            </p>
        </div>
        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small"
                  OnClick='() => Nav.NavigateTo("/admin/users/create")'>
            <LucideIcon Name="user-plus" class="h-4 w-4 mr-1.5" />
            Create User
        </BbButton>
    </div>

    @* Search & filters *@
    <AdminSearchUsersForm @bind-searchString="_searchString"
                          pageSize="PageSizeParsed"
                          pageSizeChanged="OnPageSizeSelectChanged"
                          @bind-includeDeleted="_includeDeleted"
                          OnSearch="HandleSearchKey" />

    @* Table *@
    <BbCard>
        <BbCardContent class="p-0">
            <UserTable Users="@users" PageSize="(int)PageSizeParsed" IsLoading="@_isLoading" />
        </BbCardContent>
    </BbCard>

    @* Pagination *@
    @if (TotalPages > 1)
    {
        <div class="flex items-center justify-between text-sm text-muted-foreground">
            <span>Page @CurrentPage of @TotalPages</span>
            <BbPagination TotalPages="TotalPages"
                          CurrentPage="CurrentPage"
                          OnPageChanged="OnPageChanged" />
        </div>
    }

</div>
