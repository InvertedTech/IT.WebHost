@page "/subscribe"
@using IT.WebHost.Components.Forms
@using IT.WebHost.Core.Models

<PageTitle>Subscribe</PageTitle>

@if (_model.Tiers.Count == 0)
{
    <div class="flex flex-1 items-center justify-center py-12">
        <BbAlert Variant="AlertVariant.Warning">
            <BbAlertTitle>No Subscription Tiers</BbAlertTitle>
            <BbAlertDescription>No subscription tiers are currently available.</BbAlertDescription>
        </BbAlert>
    </div>
}
else
{
    <div class="container max-w-4xl py-12 mx-auto">
        <div class="grid gap-6 md:grid-cols-@_model.Tiers.Count">
            @foreach (var tier in _model.Tiers)
            {
                <BbCard>
                    <BbCardHeader>
                        <BbCardTitle>@tier.Name</BbCardTitle>
                        <BbCardDescription>@tier.Description</BbCardDescription>
                    </BbCardHeader>
                    <BbCardContent>
                        <p class="text-3xl font-bold">$@(tier.AmountCents / 100.0m)<span class="text-sm font-normal text-muted-foreground">/mo</span></p>
                    </BbCardContent>
                    <BbCardFooter>
                        <BbButton class="w-full" @onclick="() => OpenDialog(tier)">Subscribe</BbButton>
                    </BbCardFooter>
                </BbCard>
            }
        </div>
    </div>
    <BbDialog @bind-Open="isDialogOpen">
        <BbDialogContent>
            <BbDialogHeader>
                <BbDialogTitle>@(selectedTier?.Name) - $@(selectedTier?.AmountCents / 100.0m)</BbDialogTitle>
            </BbDialogHeader>
            <BbSelect TValue="string" @bind-Value="selectedProvider">
                <BbSelectLabel>Payment Processor</BbSelectLabel>
                <BbSelectTrigger class="w-[180px]">
                    <BbSelectValue Placeholder="Select Payment Processor" />
                </BbSelectTrigger>
                <BbSelectContent>
                    @*TODO: Programatically Build These Values Based On Settings.Public.Subscription.{Provider}.IsEnabled*@
                    <BbSelectItem Value="@("Stripe")" Text="Stripe">Stripe</BbSelectItem>
@*                     <BbSelectItem Value="@("Fortis")" Text="Fortis">Fortis</BbSelectItem>
                    <BbSelectItem Value="@("Paypal")" Text="Paypal">Paypal</BbSelectItem>
                    <BbSelectItem Value="@("Crypto")" Text="Crypto">Crypto</BbSelectItem> *@
                </BbSelectContent>
            </BbSelect>
            <BbFormFieldInput TValue="string"
                              Label="Zip/Postal Code"
                              Placeholder="Enter your zip/postal code"
                              @bind-Value="zipCode" />
            <BbDialogFooter>
                <BbButton @onclick="() => CloseDialog()">Close</BbButton>
                <BbButton @onclick="() => SubmitSubscribe()">Submit</BbButton>
            </BbDialogFooter>
        </BbDialogContent>
    </BbDialog>
}
